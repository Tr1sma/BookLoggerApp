<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1A1410"
    android:padding="24dp">

    <!-- Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Select Goal"
        android:textColor="#F5E6D3"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <!-- Subtitle -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Which reading goal should the widget display?"
        android:textColor="#C9B5A0"
        android:textSize="14sp"
        android:layout_marginBottom="16dp" />

    <!-- Goal list -->
    <ListView
        android:id="@+id/widget_config_goal_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="#4A3F32"
        android:dividerHeight="1dp" />

    <!-- Empty state -->
    <TextView
        android:id="@+id/widget_config_empty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="No active goals found.\nCreate a reading goal in BookHeart first."
        android:textColor="#8B7968"
        android:textSize="14sp"
        android:gravity="center"
        android:visibility="gone" />

    <!-- Confirm button -->
    <Button
        android:id="@+id/widget_config_confirm"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Confirm"
        android:textColor="#1A1410"
        android:backgroundTint="#D4A574"
        android:layout_marginTop="16dp" />
</LinearLayout>
