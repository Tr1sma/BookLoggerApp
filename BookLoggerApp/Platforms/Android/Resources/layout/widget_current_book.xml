<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@drawable/widget_background"
    android:padding="12dp"
    android:gravity="center_vertical"
    android:id="@+id/widget_current_book_root">

    <!-- Cover Image -->
    <ImageView
        android:id="@+id/widget_cover_image"
        android:layout_width="56dp"
        android:layout_height="84dp"
        android:scaleType="centerCrop"
        android:src="@drawable/widget_placeholder_cover"
        android:contentDescription="Book cover" />

    <!-- Book Info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp"
        android:gravity="start">

        <!-- Title -->
        <TextView
            android:id="@+id/widget_book_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No active book"
            android:textColor="@color/widget_text_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:maxLines="2"
            android:ellipsize="end" />

        <!-- Author -->
        <TextView
            android:id="@+id/widget_book_author"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/widget_text_secondary"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginTop="2dp" />

        <!-- Progress Bar -->
        <ProgressBar
            android:id="@+id/widget_progress_bar"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="8dp"
            android:max="100"
            android:progress="0"
            android:progressDrawable="@drawable/widget_progress_bar" />

        <!-- Page Info -->
        <TextView
            android:id="@+id/widget_page_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tap to open BookHeart"
            android:textColor="@color/widget_text_muted"
            android:textSize="11sp"
            android:layout_marginTop="4dp" />
    </LinearLayout>
</LinearLayout>
