    private async Task HandleRenamePlantFromModal(string newName)
    {
        if (selectedPlant == null)
        {
            return;
        }

        var plantId = selectedPlant.Id;
        var plantToRename = selectedPlant;
        var trimmedName = newName.Trim();
        if (string.IsNullOrWhiteSpace(trimmedName))
        {
            throw new InvalidOperationException("Plant name cannot be empty");
        }

        if (trimmedName.Length > 100)
        {
            throw new InvalidOperationException("Plant name cannot exceed 100 characters");
        }

        if (string.Equals(trimmedName, selectedPlant.Name, StringComparison.Ordinal))
        {
            return;
        }

        isRenamingPlant = true;

        try
        {
            await ViewModel.RenamePlantCommand.ExecuteAsync((plantId, trimmedName));
            if (!string.IsNullOrWhiteSpace(ViewModel.ErrorMessage))
            {
                throw new InvalidOperationException(ViewModel.ErrorMessage);
            }

            plantToRename.Name = trimmedName;

            var refreshedPlant = await ViewModel.GetPlantByIdAsync(plantId);
            if (!string.IsNullOrWhiteSpace(ViewModel.ErrorMessage))
            {
                throw new InvalidOperationException(ViewModel.ErrorMessage);
            }

            if (selectedPlant?.Id == plantId)
            {
                selectedPlant = refreshedPlant ?? plantToRename;
            }
        }
        finally
        {
            isRenamingPlant = false;
        }
    }
    private async Task HandleWaterPlantFromModal()
    {
        if (selectedPlant != null)
        {
            var plantId = selectedPlant.Id;
            isWateringPlant = true;

            try
            {
                await ViewModel.WaterPlantCommand.ExecuteAsync(plantId);
                selectedPlant = await ViewModel.GetPlantByIdAsync(plantId);

                if (string.IsNullOrWhiteSpace(ViewModel.ErrorMessage))
                {
                    await OnboardingService.TrackEventAsync(OnboardingEvent.PlantWatered, plantId);
                }
            }
            finally
            {
                isWateringPlant = false;
            }
        }
    }
    private async Task HandleRemoveSelectedPlantFromShelf()
    {
        if (selectedPlant == null || !selectedPlantShelfId.HasValue)
        {
            return;
        }

        isRemovingPlant = true;

        try
        {
            await ViewModel.RemovePlantFromShelfCommand.ExecuteAsync((selectedPlant.Id, selectedPlantShelfId.Value));
            if (string.IsNullOrWhiteSpace(ViewModel.ErrorMessage))
            {
                ClosePlantDetail();
            }
        }
        finally
        {
            isRemovingPlant = false;
        }
    }

    private async Task HandleSelectedPlantAction()
    {
        if (IsSelectedPlantDead)
        {
            await HandleDeleteSelectedPlant();
            return;
        }

        await HandleRemoveSelectedPlantFromShelf();
    }

    private async Task HandleDeleteSelectedPlant()
    {
        if (selectedPlant == null)
        {
            return;
        }

        isRemovingPlant = true;

        try
        {
            await ViewModel.DeletePlantCommand.ExecuteAsync(selectedPlant.Id);
            if (string.IsNullOrWhiteSpace(ViewModel.ErrorMessage))
            {
                ClosePlantDetail();
            }
        }
        finally
        {
            isRemovingPlant = false;
        }
    }

    private string GetSelectedPlantActionLabel()
    {
        if (isRemovingPlant)
        {
            return IsSelectedPlantDead ? L["Bookshelf_Deleting"] : L["Bookshelf_Removing"];
        }

        return IsSelectedPlantDead ? L["Bookshelf_DeletePlant"] : L["Bookshelf_RemoveFromShelf"];
    }

