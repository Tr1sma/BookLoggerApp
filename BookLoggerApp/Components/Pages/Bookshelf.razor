@page "/"
@page "/bookshelf"
@using BookLoggerApp.Core.ViewModels
@using BookLoggerApp.Core.Models
@using BookLoggerApp.Core.Enums
@using BookLoggerApp.Core.Resources
@using BookLoggerApp.Core.Services.Abstractions
@using BookLoggerApp.Core.Entitlements
@using BookLoggerApp.Components.Shared
@using Microsoft.Extensions.Localization
@inject BookshelfViewModel ViewModel
@inject Microsoft.AspNetCore.Components.NavigationManager Navigation
@inject IGoalService GoalService
@inject BookLoggerApp.Core.Services.Abstractions.IBackButtonService BackButtonService
@inject WishlistViewModel WishlistVM
@inject BookLoggerApp.Services.IScannerService ScannerService
@inject IOnboardingService OnboardingService
@inject IJSRuntime JSRuntime
@inject IDatabaseInitializer DatabaseInitializer
@inject IStringLocalizer<AppResources> L
@inherits BookLoggerApp.Components.ObservableComponentBase
@implements IAsyncDisposable

<PageTitle>@L["PageTitle_Bookshelf"] - BookHeart</PageTitle>


<AnalyticsScreenTracker Screen="@BookLoggerApp.Core.Services.Analytics.ScreenNames.Bookshelf" />
<div class="bookshelf-container" style="--shelf-ledge-color: @ViewModel.ShelfLedgeColor; --shelf-base-color: @ViewModel.ShelfBaseColor">
    <GettingStartedCta />

    <!-- Reading Goal Header -->
    <GoalHeader TbrCount="@ViewModel.TbrCount" GoalTarget="@ViewModel.GoalTarget"
        BooksRead="@ViewModel.BooksReadThisYear" BooksRemaining="@ViewModel.BooksRemainingToGoal" />

    <!-- Tab Bar -->
    <div class="bookshelf-tabs">
        <button class="tab-btn @(activeTab == "shelves" ? "active" : "")"
                @onclick='() => SwitchTab("shelves")'>
            @L["Bookshelf_Tab_Shelves"]
        </button>
        <button class="tab-btn @(activeTab == "wishlist" ? "active" : "")"
                @onclick='() => SwitchTab("wishlist")'>
            @L["Bookshelf_Tab_Wishlist"]
            @if (WishlistVM.WishlistCount > 0)
            {
                <span class="wishlist-count-badge">@WishlistVM.WishlistCount</span>
            }
        </button>
    </div>

    @if (activeTab == "shelves")
    {
    <!-- Header & Controls -->
    <div class="bookshelf-header">
        <h1>@L["Bookshelf_Title"]</h1>
        <div class="bookshelf-controls">
            <input type="text" class="search-input" placeholder="@L["Bookshelf_SearchPlaceholder"]"
                   value="@ViewModel.SearchQuery"
                   @oninput="HandleSearchInput" />
        </div>
    </div>

    <!-- Filters & Sort (Collapsible) -->
    <div class="bookshelf-filters-wrapper">
        <button class="filter-toggle-btn" @onclick="ToggleFilters">
            <span>@(filtersExpanded ? "▼" : "▶") @L["Bookshelf_FiltersSort"]</span>
            @if (HasActiveFilters())
            {
                <span class="active-filter-badge">@L["Bookshelf_Active"]</span>
            }
        </button>

        <div class="bookshelf-filters @(filtersExpanded ? "expanded" : "collapsed")">
            <!-- Existing filters... -->
            <div class="filter-group">
                <label>@L["Bookshelf_SortBy"]</label>
                <select value="@ViewModel.SortBy"
                @onchange="@((ChangeEventArgs e) => { ViewModel.SortBy = e.Value?.ToString() ?? "Title"; HandleSearch(); })">
                    <option value="Title">@L["Bookshelf_Sort_Title"]</option>
                    <option value="Author">@L["BookEdit_Author"]</option>
                    <option value="DateAdded">@L["Bookshelf_Sort_DateAdded"]</option>
                    <option value="Status">@L["BookDetail_Status"]</option>
                </select>
            </div>
            <!-- ... (Keeping filters simple for now, as search clears shelves) -->
            <div class="filter-group">
                <button class="btn btn-secondary" @onclick="HandleClearFilters">@L["Bookshelf_ClearFilters"]</button>
            </div>
        </div>
    </div>

    <!-- Book Grid / Shelves -->
    @if (ViewModel.IsBusy)
    {
        <div class="loading">@L["Bookshelf_Loading"]</div>
    }
    else if (!string.IsNullOrEmpty(ViewModel.ErrorMessage))
    {
        <div class="alert alert-danger">
            <p>@ViewModel.ErrorMessage</p>
            <button class="btn btn-primary" @onclick="RetryLoadAsync">@L["Common_Retry"]</button>
        </div>
    }
    else if (!string.IsNullOrEmpty(ViewModel.SearchQuery) || ViewModel.FilterStatus.HasValue ||
    ViewModel.FilterGenreId.HasValue)
    {
        <!-- Search Results View (Flat Grid) -->
        <div class="search-results-label">@L["Bookshelf_SearchResults", ViewModel.Books.Count]</div>
        <div class="book-grid">
            <div class="shelf-row">
                <Virtualize Items="@ViewModel.Books" Context="book" OverscanCount="5">
                    <div class="shelf-slot">
                        <BookCard Book="@book" IsInBookshelf="true" OnClick="() => HandleBookClick(book)"
                            OnDelete="() => HandleDeleteBook(book.Id)" />
                    </div>
                </Virtualize>
            </div>
        </div>
    }
    else
    {
        <!-- Shelves View -->
        <div class="shelves-container">
            @{ var hasAvailablePlants = ViewModel.AvailablePlants.Any(); }
            @for (var shelfIndex = 0; shelfIndex < ViewModel.Shelves.Count; shelfIndex++)
            {
                var shelfVM = ViewModel.Shelves[shelfIndex];
                var isFirst = shelfIndex == 0;
                var isLast = shelfIndex == ViewModel.Shelves.Count - 1;

                <div @key="shelfVM.Shelf.Id"
                     class="shelf-section @(shelfVM.IsExpanded ? "" : "collapsed")"
                     data-shelf-id="@shelfVM.Shelf.Id"
                     data-auto-sort="@(shelfVM.Shelf.AutoSortRule != ShelfAutoSortRule.None ? "true" : "false")">

                    <div class="shelf-header">
                        <div style="display: flex; align-items: center; gap: 10px;">
                            <button class="btn-icon toggle-icon @(shelfVM.IsExpanded ? "" : "collapsed")"
                            @onclick="() => shelfVM.IsExpanded = !shelfVM.IsExpanded">
                                ▼
                            </button>
                            <h3>@shelfVM.Shelf.Name</h3>
                            <!-- Reordering Controls -->
                            <div class="shelf-reorder-controls" style="display: flex; gap: 2px; margin-left: 10px;">
                                <button class="btn-icon small"
                                @onclick="() => ViewModel.MoveShelfUpCommand.ExecuteAsync(shelfVM.Shelf.Id)"
                                    disabled="@isFirst" title="@L["Bookshelf_MoveUp"]">
                                    ⬆️
                                </button>
                                <button class="btn-icon small"
                                @onclick="() => ViewModel.MoveShelfDownCommand.ExecuteAsync(shelfVM.Shelf.Id)"
                                    disabled="@isLast"
                                    title="@L["Bookshelf_MoveDown"]">
                                    ⬇️
                                </button>
                            </div>
                        </div>

                        <div class="shelf-actions">
                            @if (shelfVM.Shelf.SortOrder > 0)
                            {
                                <button class="btn-icon" @onclick="() => HandleDeleteShelf(shelfVM.Shelf.Id)"
                                    title="@L["Bookshelf_DeleteShelfTitle"]">🗑️</button>
                            }
                        </div>
                    </div>
                    @if (shelfVM.IsExpanded)
                    {
                        <div class="shelf-books">
                            <!-- Mixed Items Loop -->
                            @foreach (var item in shelfVM.Items)
                            {
                                @if (item.Type == ShelfItemType.Book && item.Book != null)
                                {
                                    <div @key="item.Book.Id"
                                         class="shelf-slot @(item.SlotWidth > 1 ? "slot-wide-" + item.SlotWidth : "")"
                                         data-item-id="@item.Book.Id"
                                         data-item-type="Book"
                                         data-shelf-id="@shelfVM.Shelf.Id"
                                         data-slot-width="@item.SlotWidth">
                                        <BookCard Book="@item.Book" IsInBookshelf="true"
                                            OnClick="() => HandleBookClick(item.Book)"
                                            OnDelete="() => HandleRemoveBookFromShelf(item.Book.Id, shelfVM.Shelf.Id)" />
                                    </div>
                                }
                                else if (item.Type == ShelfItemType.Plant && item.Plant != null)
                                {
                                    <div @key="item.Plant.Id"
                                         class="shelf-slot @(item.SlotWidth > 1 ? "slot-wide-" + item.SlotWidth : "")"
                                         data-item-id="@item.Plant.Id"
                                         data-item-type="Plant"
                                         data-shelf-id="@shelfVM.Shelf.Id"
                                         data-slot-width="@item.SlotWidth">
                                        <PlantCard Plant="@item.Plant" IsInBookshelf="true"
                                            ShowActions="false"
                                            OnClick="() => HandlePlantClick(item.Plant, shelfVM.Shelf.Id)" />
                                    </div>
                                }
                                else if (item.Type == ShelfItemType.Decoration && item.Decoration != null)
                                {
                                    <div @key="item.Decoration.Id"
                                         class="shelf-slot @(item.SlotWidth > 1 ? "slot-wide-" + item.SlotWidth : "")"
                                         data-item-id="@item.Decoration.Id"
                                         data-item-type="Decoration"
                                         data-shelf-id="@shelfVM.Shelf.Id"
                                         data-slot-width="@item.SlotWidth">
                                        <DecorationCard Decoration="@item.Decoration" IsInBookshelf="true"
                                            ShowActions="false"
                                            OnClick="() => HandleDecorationClick(item.Decoration, shelfVM.Shelf.Id)" />
                                    </div>
                                }
                            }

                            <!-- Add Plant Button -->
                            @if (hasAvailablePlants)
                            {
                                <div class="empty-slot" @onclick="() => HandleAddPlant(shelfVM.Shelf.Id)">
                                    <div class="empty-slot-icon">🌱</div>
                                    <div class="empty-slot-text">@L["Bookshelf_AddPlant"]</div>
                                </div>
                            }

                            <!-- Add Decoration Button -->
                            @if (ViewModel.AvailableDecorations.Any())
                            {
                                <div class="empty-slot" @onclick="() => HandleAddDecoration(shelfVM.Shelf.Id)">
                                    <div class="empty-slot-icon">🕯️</div>
                                    <div class="empty-slot-text">@L["Bookshelf_AddDeco"]</div>
                                </div>
                            }
                        </div>
                        <div class="shelf-wood-base"></div>
                    }
                </div>
            }
        </div>
    }
    <!-- Floating Action Buttons (Shelves Tab) -->
    <div class="fab-container">
        <LockedFeatureButton Feature="FeatureKey.UnlimitedShelves"
                             ForceLock="@(ViewModel.Shelves.Count >= 3)">
            <button class="fab-button secondary" @onclick="OpenAddShelfModal" title="@L["Bookshelf_NewShelf"]">
                📚
            </button>
        </LockedFeatureButton>
        <button class="fab-button" @onclick="NavigateToAddBook" title="@L["Bookshelf_AddBook"]">
            +
        </button>
    </div>
    } @* end activeTab == "shelves" *@

    @if (activeTab == "wishlist")
    {
    <LockedFeatureButton Feature="FeatureKey.Wishlist">
    <!-- Wishlist Content -->
    <div class="wishlist-controls">
        <input type="text" class="search-input" placeholder="@L["Wishlist_SearchPlaceholder"]"
               value="@WishlistVM.SearchQuery"
               @oninput="HandleWishlistSearchInput" />
        <select class="wishlist-sort-select" value="@WishlistVM.SortBy"
                @onchange="HandleWishlistSort">
            <option value="DateAdded">@L["Bookshelf_Sort_DateAdded"]</option>
            <option value="Priority">@L["BookDetail_Priority"]</option>
            <option value="Title">@L["Bookshelf_Sort_Title"]</option>
            <option value="Author">@L["BookEdit_Author"]</option>
        </select>
    </div>

    @if (WishlistVM.IsBusy)
    {
        <div class="loading">@L["Wishlist_Loading"]</div>
    }
    else if (!WishlistVM.WishlistBooks.Any())
    {
        <div class="wishlist-empty">
            <div class="wishlist-empty-icon">💝</div>
            <div class="wishlist-empty-text">@L["Wishlist_Empty_Text"]</div>
            <div class="wishlist-empty-hint">@L["Wishlist_Empty_Hint"]</div>
        </div>
    }
    else
    {
        <div class="wishlist-book-list">
            @foreach (var book in WishlistVM.WishlistBooks)
            {
                <div class="wishlist-card" @onclick="() => HandleBookClick(book)">
                    <div class="wishlist-card-cover">
                        @if (!string.IsNullOrEmpty(book.CoverImagePath))
                        {
                            <img src="@book.CoverImagePath" alt="@book.Title" />
                        }
                        else
                        {
                            <span class="no-cover">📖</span>
                        }
                    </div>
                    <div class="wishlist-card-info">
                        <div class="wishlist-card-title">@book.Title</div>
                        <div class="wishlist-card-author">@book.Author</div>
                        <div class="wishlist-card-meta">
                            @if (book.WishlistInfo != null)
                            {
                                <span class="wishlist-priority priority-@book.WishlistInfo.Priority.ToString().ToLower()">
                                    @book.WishlistInfo.Priority
                                </span>
                                @if (!string.IsNullOrEmpty(book.WishlistInfo.RecommendedBy))
                                {
                                    <span class="wishlist-card-recommended">
                                        @L["Wishlist_RecommendedPrefix"] @book.WishlistInfo.RecommendedBy
                                    </span>
                                }
                            }
                        </div>
                    </div>
                    <div class="wishlist-card-actions" @onclick:stopPropagation="true">
                        <button class="btn-icon" @onclick="() => NavigateToEditBook(book.Id)" title="@L["Wishlist_EditAndAdd"]">
                            📚
                        </button>
                        <button class="btn-icon danger" @onclick="() => HandleRemoveFromWishlist(book.Id)" title="@L["Common_Remove"]">
                            🗑️
                        </button>
                    </div>
                </div>
            }
        </div>
    }

    <!-- Floating Action Button (Wishlist Tab) -->
    <div class="fab-container">
        <button class="fab-button" @onclick="OpenAddToWishlistModal" title="@L["Wishlist_AddTitle"]">
            +
        </button>
    </div>
    </LockedFeatureButton>
    } @* end activeTab == "wishlist" *@
</div>

<!-- Add Shelf Modal -->
@if (showAddShelfModal)
{
    <div class="modal-overlay" @onclick="CloseAddShelfModal">
        <div class="modal-content" @onclick:stopPropagation="true">
            <h3>@L["Bookshelf_AddShelf_Title"]</h3>
            <div class="form-group">
                <label>@L["Bookshelf_AddShelf_Name"]</label>
                <input type="text" @bind="newShelfName" class="form-control" placeholder="@L["Bookshelf_AddShelf_Placeholder"]" />
            </div>
            <div class="form-group">
                <label>@L["Bookshelf_AutoSortRule"]</label>
                <select @bind="newShelfRule" class="form-control">
                    <option value="@ShelfAutoSortRule.None">@L["Bookshelf_AutoSort_None"]</option>
                    <option value="@ShelfAutoSortRule.StatusPlanned">@L["Bookshelf_AutoSort_Planned"]</option>
                    <option value="@ShelfAutoSortRule.StatusReading">@L["Bookshelf_AutoSort_Reading"]</option>
                    <option value="@ShelfAutoSortRule.StatusCompleted">@L["Bookshelf_AutoSort_Completed"]</option>
                    <option value="@ShelfAutoSortRule.StatusWishlist">@L["Bookshelf_AutoSort_Wishlist"]</option>
                </select>
                <small>@L["Bookshelf_AutoSort_Hint"]</small>
            </div>
            <div class="modal-actions">
                <button class="btn btn-secondary" @onclick="CloseAddShelfModal">@L["Common_Cancel"]</button>
                <button class="btn btn-primary" @onclick="CreateShelf">@L["Bookshelf_CreateShelf"]</button>
            </div>
        </div>
    </div>
}

<!-- ... Plant/Book Modals (Keep existing ones) ... -->
<!-- Plant Detail Modal -->
@if (showPlantDetail && selectedPlant != null)
{
    <div class="modal-overlay" @onclick="ClosePlantDetail">
        <div class="modal-content plant-detail-modal" @onclick:stopPropagation="true">
            <div class="plant-detail-modal-header">
                <h3>@L["Bookshelf_PlantDetails"]</h3>
                <button class="plant-detail-close" @onclick="ClosePlantDetail">×</button>
            </div>

            <PlantDetailCard Plant="@selectedPlant"
                             OnRename="HandleRenamePlantFromModal"
                             OnWater="HandleWaterPlantFromModal"
                             IsWatering="@isWateringPlant"
                             IsRenaming="@isRenamingPlant" />

            <div class="modal-actions">
                <button class="btn btn-secondary" @onclick="ClosePlantDetail">@L["Common_Close"]</button>
                @if (selectedPlantShelfId.HasValue)
                {
                    <button class="btn btn-danger"
                            @onclick="HandleSelectedPlantAction"
                            disabled="@isRemovingPlant">
                        @GetSelectedPlantActionLabel()
                    </button>
                }
            </div>
        </div>
    </div>
}

<!-- Plant Selector Modal -->
@if (showPlantSelector)
{
    <div class="modal-overlay" @onclick="ClosePlantSelector">
        <div class="modal-content" @onclick:stopPropagation="true">
            <h3>@L["Bookshelf_SelectPlant"]</h3>
            <div class="plant-selector-grid" style="display: flex; flex-wrap: wrap; gap: 10px; padding: 10px 0;">
                @if (ViewModel.AvailablePlants.Any())
                {
                    @foreach (var plant in ViewModel.AvailablePlants)
                    {
                        <div class="plant-select-item" @onclick="() => SelectPlantForBookshelf(plant)"
                            style="cursor: pointer; transform: scale(0.9);">
                            <PlantCard Plant="@plant" IsInBookshelf="false" />
                        </div>
                    }
                }
                else
                {
                    <p style="color: #ccc; width: 100%; text-align: center;">@L["Bookshelf_NoPlantsAvailable"]</p>
                    <button class="btn btn-primary" @onclick="@(() => Navigation.NavigateTo("/shop"))" style="width: 100%;">@L["Bookshelf_GoToShop"]</button>
                }
            </div>
            <div class="modal-actions">
                <button class="btn btn-secondary" @onclick="ClosePlantSelector">@L["Common_Cancel"]</button>
            </div>
        </div>
    </div>
}
<!-- Decoration Selector Modal -->
@if (showDecorationSelector)
{
    <div class="modal-overlay" @onclick="CloseDecorationSelector">
        <div class="modal-content" @onclick:stopPropagation="true">
            <h3>@L["Bookshelf_SelectDecoration"]</h3>
            <div class="plant-selector-grid" style="display: flex; flex-wrap: wrap; gap: 10px; padding: 10px 0;">
                @if (ViewModel.AvailableDecorations.Any())
                {
                    @foreach (var deco in ViewModel.AvailableDecorations)
                    {
                        <div class="plant-select-item" @onclick="() => SelectDecorationForBookshelf(deco)"
                            style="cursor: pointer; transform: scale(0.9);">
                            <DecorationCard Decoration="@deco" IsInBookshelf="false" ShowActions="false" />
                        </div>
                    }
                }
                else
                {
                    <p style="color: #ccc; width: 100%; text-align: center;">@L["Bookshelf_NoDecorationsAvailable"]</p>
                    <button class="btn btn-primary" @onclick="@(() => Navigation.NavigateTo("/shop"))" style="width: 100%;">@L["Bookshelf_GoToShop"]</button>
                }
            </div>
            <div class="modal-actions">
                <button class="btn btn-secondary" @onclick="CloseDecorationSelector">@L["Common_Cancel"]</button>
            </div>
        </div>
    </div>
}

<!-- Decoration Detail Modal -->
@if (showDecorationDetail && selectedDecoration != null)
{
    <div class="modal-overlay" @onclick="CloseDecorationDetail">
        <div class="modal-content" @onclick:stopPropagation="true">
            <h3>@selectedDecoration.LocalizedDisplayName(L)</h3>
            <div style="text-align: center; padding: 1rem 0;">
                <img src="@(selectedDecoration.ShopItem?.ImagePath ?? "images/decorations/placeholder.svg")"
                     alt="@selectedDecoration.LocalizedDisplayName(L)"
                     style="max-width: 120px; max-height: 120px;" />
            </div>
            @if (selectedDecoration.ShopItem != null)
            {
                <p style="color: var(--text-secondary); text-align: center; margin-bottom: 1rem;">@selectedDecoration.ShopItem.LocalizedDescription(L)</p>
            }
            <div class="modal-actions">
                <button class="btn btn-secondary" @onclick="CloseDecorationDetail">@L["Common_Close"]</button>
                @if (selectedDecorationShelfId.HasValue)
                {
                    <button class="btn btn-danger" @onclick="HandleRemoveDecorationFromShelf">
                        @L["Bookshelf_RemoveFromShelf"]
                    </button>
                }
            </div>
        </div>
    </div>
}

<!-- Delete Shelf Confirmation Modal -->
@if (showDeleteShelfModal)
{
    <div class="modal-overlay" @onclick="CloseDeleteShelfModal">
        <div class="modal-content" @onclick:stopPropagation="true">
            <h3>@L["Bookshelf_DeleteShelf_Title"]</h3>
            <p>@L["Bookshelf_DeleteShelf_Body"]</p>
            <div class="modal-actions">
                <button class="btn btn-secondary" @onclick="CloseDeleteShelfModal">@L["Common_Cancel"]</button>
                <button class="btn btn-danger" @onclick="ConfirmDeleteShelf">@L["Common_Delete"]</button>
            </div>
        </div>
    </div>
}

<!-- Add to Wishlist Modal -->
@if (showAddToWishlistModal)
{
    <div class="modal-overlay" @onclick="CloseAddToWishlistModal">
        <div class="modal-content" @onclick:stopPropagation="true">
            <h3>@L["Wishlist_AddTitle"]</h3>
            <div class="wishlist-form">
                <div class="wishlist-isbn-row">
                    <div class="form-group">
                        <label>ISBN</label>
                        <input type="text" class="form-control" placeholder="@L["Wishlist_EnterIsbn"]"
                               @bind="WishlistVM.NewIsbn" />
                    </div>
                    <button class="btn-icon wishlist-isbn-btn"
                            @onclick="ScanWishlistIsbnAsync" title="@L["Wishlist_ScanBarcode"]">
                        📷
                    </button>
                    <button class="btn-icon wishlist-isbn-btn"
                            @onclick="HandleWishlistLookup" disabled="@WishlistVM.IsLookingUp"
                            title="@L["Wishlist_LookupIsbn"]">
                        🔍
                    </button>
                </div>
                @if (WishlistVM.LookupMessage != null)
                {
                    <div class="wishlist-lookup-msg @(WishlistVM.LookupMessage.Contains("found") ? "success" : "error")">
                        @WishlistVM.LookupMessage
                    </div>
                }
                <div class="form-group">
                    <label>@L["BookEdit_Title"] *</label>
                    <input type="text" class="form-control" placeholder="@L["Wishlist_TitlePlaceholder"]"
                           @bind="WishlistVM.NewTitle" />
                </div>
                <div class="form-group">
                    <label>@L["BookEdit_Author"] *</label>
                    <input type="text" class="form-control" placeholder="@L["Wishlist_AuthorPlaceholder"]"
                           @bind="WishlistVM.NewAuthor" />
                </div>
                <div class="form-group">
                    <label>@L["BookDetail_Priority"]</label>
                    <div class="priority-select">
                        <button class="priority-option @(WishlistVM.NewPriority == WishlistPriority.Low ? "selected" : "")"
                                @onclick="() => WishlistVM.NewPriority = WishlistPriority.Low">@L["Priority_Low"]</button>
                        <button class="priority-option @(WishlistVM.NewPriority == WishlistPriority.Medium ? "selected" : "")"
                                @onclick="() => WishlistVM.NewPriority = WishlistPriority.Medium">@L["Priority_Medium"]</button>
                        <button class="priority-option @(WishlistVM.NewPriority == WishlistPriority.High ? "selected" : "")"
                                @onclick="() => WishlistVM.NewPriority = WishlistPriority.High">@L["Priority_High"]</button>
                    </div>
                </div>
                <div class="form-group">
                    <label>@L["BookDetail_RecommendedBy"]</label>
                    <input type="text" class="form-control" placeholder="@L["Wishlist_RecommendedPlaceholder"]"
                           @bind="WishlistVM.NewRecommendedBy" />
                </div>
                <div class="form-group">
                    <label>@L["BookDetail_Notes"]</label>
                    <textarea class="form-control" placeholder="@L["Wishlist_NotesPlaceholder"]"
                              @bind="WishlistVM.NewWishlistNotes"></textarea>
                </div>
            </div>
            <div class="modal-actions">
                <button class="btn btn-secondary" @onclick="CloseAddToWishlistModal">@L["Common_Cancel"]</button>
                <button class="btn btn-primary" @onclick="HandleAddToWishlist"
                        disabled="@(string.IsNullOrWhiteSpace(WishlistVM.NewTitle))">@L["Bookshelf_Add"]</button>
            </div>
        </div>
    </div>
}

@code {
    private string activeTab = "shelves";
    private bool filtersExpanded = false;
    private bool showAddShelfModal = false;
    private string newShelfName = "";
    private ShelfAutoSortRule newShelfRule = ShelfAutoSortRule.None;
    private bool showAddToWishlistModal = false;

    // Plant state
    private bool showPlantDetail;
    private UserPlant? selectedPlant;
    private Guid? selectedPlantShelfId;
    private bool isRenamingPlant;
    private bool isWateringPlant;
    private bool isRemovingPlant;
    private bool IsSelectedPlantDead => selectedPlant?.Status == PlantStatus.Dead;

    // JS Drag & Drop interop
    private DotNetObjectReference<Bookshelf>? _dotNetHelper;
    private bool _jsInitialized = false;

    // Back handler
    private Func<Task<bool>>? _activeBackHandler;

    protected override async Task OnInitializedAsync()
    {
        Observe(ViewModel);
        Observe(WishlistVM);
        GoalService.GoalsChanged += OnGoalsChanged;
        await ViewModel.LoadCommand.ExecuteAsync(null);
    }

    private async Task RetryLoadAsync()
    {
        // Always trigger a fresh DB init: after a ViewModel-level TimeoutException
        // the helper's InitializationFailed flag is false, so gating on it would
        // leave the original pending TCS in place and the retry would just wait
        // for it again.
        DatabaseInitializer.Retry();
        await ViewModel.LoadCommand.ExecuteAsync(null);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_jsInitialized && ViewModel.Shelves.Any() && activeTab == "shelves")
        {
            _dotNetHelper?.Dispose();
            _dotNetHelper = DotNetObjectReference.Create(this);
            await JSRuntime.InvokeVoidAsync("bookshelfDragDrop.init", _dotNetHelper);
            _jsInitialized = true;
        }
    }

    private async void OnGoalsChanged(object? sender, EventArgs e)
    {
        try
        {
            await InvokeAsync(async () =>
            {
                // Only refresh goal header stats — shelves are unchanged
                await ViewModel.RefreshGoalStatsAsync();
                StateHasChanged();
            });
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Failed to refresh bookshelf goal stats: {ex.Message}");
        }
    }

    public async ValueTask DisposeAsync()
    {
        GoalService.GoalsChanged -= OnGoalsChanged;
        if (_activeBackHandler != null)
        {
            BackButtonService.Unregister(_activeBackHandler);
            _activeBackHandler = null;
        }
        _searchTimer?.Stop();
        _searchTimer?.Dispose();
        _wishlistSearchTimer?.Stop();
        _wishlistSearchTimer?.Dispose();
        try
        {
            await JSRuntime.InvokeVoidAsync("bookshelfDragDrop.dispose");
        }
        catch { /* Ignore if JS runtime already gone */ }
        _dotNetHelper?.Dispose();
        Dispose();
    }

