@page "/stats"
@page "/level-overview"
@using BookLoggerApp.Core.ViewModels
@using BookLoggerApp.Core.Models
@using BookLoggerApp.Core.Resources
@using BookLoggerApp.Core.Entitlements
@using Microsoft.Extensions.Localization
@inject StatsViewModel ViewModel
@inject NavigationManager NavigationManager
@inject BookLoggerApp.Core.Services.Abstractions.IBackButtonService BackButtonService
@inject BookLoggerApp.Core.Services.Abstractions.IShareService ShareService
@inject BookLoggerApp.Core.Services.Abstractions.IOnboardingService OnboardingService
@inject IStringLocalizer<AppResources> L
@inherits BookLoggerApp.Components.ObservableComponentBase
@implements IDisposable
@using System.Globalization

<PageTitle>@L["PageTitle_Stats"] - BookHeart</PageTitle>


<AnalyticsScreenTracker Screen="@BookLoggerApp.Core.Services.Analytics.ScreenNames.Stats" />
<link rel="stylesheet" href="css/stats.css" />

<div class="stats-tab-bar">
    <button class="@TabClass(0)" @onclick="() => SetTab(0)">@L["Stats_Tab_Overview"]</button>
    <button class="@TabClass(1)" @onclick="() => SetTab(1)">@L["Stats_Tab_Trends"]</button>
    <button class="@TabClass(2)" @onclick="() => SetTab(2)">@L["Stats_Tab_Insights"]</button>
</div>

@if (activeTab == 0)
{
<div class="level-overview-container">
    @if (ViewModel.IsBusy)
    {
        <div class="loading">@L["Stats_Loading"]</div>
    }
    else if (!string.IsNullOrEmpty(ViewModel.ErrorMessage))
    {
        <div class="alert alert-danger">@ViewModel.ErrorMessage</div>
    }
    else
    {
        <!-- Hero Section: Level Badge, XP Progress, Coins -->
        <section class="hero-section">
            <div class="level-hero-card">
                <!-- Large Level Badge -->
                <div class="level-badge-hero">
                    <div class="badge-inner">
                        <div class="level-number">@ViewModel.CurrentLevel</div>
                        <div class="level-label">@L["Stats_LevelLabel"]</div>
                    </div>
                </div>

                <!-- XP Progress -->
                <div class="xp-progress-section">
                    <h2 class="hero-title">🏆 @L["Stats_YourProgress"]</h2>
                    <div class="xp-text">@ViewModel.CurrentLevelXp / @ViewModel.NextLevelXp XP</div>
                    <div class="xp-progress-bar-container">
                        <div class="xp-progress-bar">
                            <div class="xp-progress-fill" style="width: @ViewModel.ProgressPercentage.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)%"></div>
                        </div>
                    </div>
                    <div class="xp-percentage-text">@L["Stats_ProgressToLevel", ViewModel.ProgressPercentage.ToString("F1"), ViewModel.CurrentLevel + 1]</div>
                </div>

                <!-- Coins -->
                <div class="coins-display">
                    <span class="coins-icon">💰</span>
                    <span class="coins-amount">@ViewModel.TotalCoins</span>
                    <span class="coins-label">@L["Stats_Coins"]</span>
                </div>
            </div>
        </section>

        <!-- Stats - Compact Chips -->
        <section class="stats-chips-section">
            <div class="stats-section-header">
                <h2>📊 @L["Stats_YourStats"]</h2>
                <LockedFeatureButton Feature="FeatureKey.ShareCards">
                    <button class="share-stats-btn" @onclick="OpenShareModal">
                        📤 @L["Stats_ShareStats"]
                    </button>
                </LockedFeatureButton>
            </div>
            <div class="stats-chips">
                <span class="stat-chip">
                    <span class="stat-chip-icon">⭐</span>
                    <span class="stat-chip-value">@ViewModel.TotalXp</span>
                    <span class="stat-chip-label">XP</span>
                </span>
                <span class="stat-chip">
                    <span class="stat-chip-icon">💰</span>
                    <span class="stat-chip-value">@ViewModel.TotalCoins</span>
                    <span class="stat-chip-label">@L["Stats_Chip_Coins"]</span>
                </span>
                <span class="stat-chip">
                    <span class="stat-chip-icon">🌱</span>
                    <span class="stat-chip-value">+@((ViewModel.TotalPlantBoost * 100).ToString("F0"))%</span>
                    <span class="stat-chip-label">@L["Stats_Chip_Boost"]</span>
                </span>
                <span class="stat-chip">
                    <span class="stat-chip-icon">📚</span>
                    <span class="stat-chip-value">@ViewModel.TotalBooksRead</span>
                    <span class="stat-chip-label">@L["Stats_Chip_Books"]</span>
                </span>
                <span class="stat-chip">
                    <span class="stat-chip-icon">📄</span>
                    <span class="stat-chip-value">@ViewModel.TotalPagesRead</span>
                    <span class="stat-chip-label">@L["Stats_Chip_Pages"]</span>
                </span>
                <span class="stat-chip">
                    <span class="stat-chip-icon">⏱️</span>
                    <span class="stat-chip-value">@FormatMinutes(ViewModel.TotalMinutesRead)</span>
                </span>
                <span class="stat-chip">
                    <span class="stat-chip-icon">🔥</span>
                    <span class="stat-chip-value">@ViewModel.CurrentStreak</span>
                    <span class="stat-chip-label">@L["Stats_Chip_DayStreak"]</span>
                </span>
                <span class="stat-chip">
                    <span class="stat-chip-icon">📈</span>
                    <span class="stat-chip-value">@ViewModel.AverageRating.ToString("F1")</span>
                    <span class="stat-chip-label">@L["Stats_Chip_Avg"]</span>
                </span>
            </div>
        </section>

        <!-- Plant Boost Section -->
        @if (ViewModel.PlantBoosts.Any() && ViewModel.TotalPlantBoost > 0m)
        {
            <section class="plant-boost-section">
                <div class="section-header">
                    <h2>🌱 @L["Stats_PlantBoosts"]</h2>
                    <div class="total-boost">
                        @L["Stats_TotalBoost"]: <span class="boost-value">+@((ViewModel.TotalPlantBoost * 100).ToString("F0"))%</span>
                    </div>
                </div>
                <div class="plant-boost-grid">
                    @foreach (var plant in ViewModel.PlantBoosts.OrderByDescending(p => p.BoostPercentage))
                    {
                        <div class="plant-boost-card" @key="plant.PlantId">
                            <div class="plant-boost-header">
                                <span class="plant-name">@plant.PlantName</span>
                                <span class="plant-level">@L["Stats_LevelAbbrev"] @plant.PlantLevel</span>
                            </div>
                            <div class="plant-boost-value">@plant.BoostDisplay</div>
                            <div class="plant-boost-bar">
                                <div class="plant-boost-fill" style="width: @(ViewModel.TotalPlantBoost > 0 ? (plant.BoostPercentage / ViewModel.TotalPlantBoost) * 100 : 0)%"></div>
                            </div>
                        </div>
                    }
                </div>
            </section>
        }

        <!-- Favorite Genre -->
        @if (!string.IsNullOrEmpty(ViewModel.FavoriteGenre))
        {
            <section class="favorite-genre-section">
                <h2>🎭 @L["Stats_FavoriteGenre"]</h2>
                <div class="favorite-genre-card">
                    <p class="genre-name">@ViewModel.FavoriteGenre</p>
                </div>
            </section>
        }

        <!-- Genre Breakdown -->
        @if (ViewModel.BooksByGenre.Any())
        {
            <section class="genre-breakdown-section">
                <h2>📖 @L["Stats_BooksByGenre"]</h2>
                <div class="genre-grid">
                    @foreach (var genre in ViewModel.BooksByGenre.OrderByDescending(g => g.Value))
                    {
                        <div class="genre-card" @key="genre.Key">
                            <div class="genre-name">@genre.Key</div>
                            <div class="genre-count">@genre.Value <span class="label">@L["Stats_Chip_Books"]</span></div>
                        </div>
                    }
                </div>
            </section>
        }

        <!-- Rating Category Averages -->
        @if (ViewModel.CategoryAverages.Any(x => x.Value > 0))
        {
            <section class="rating-averages-section">
                <h2>📊 @L["Stats_AvgByCategory"]</h2>
                <div class="rating-averages-grid">
                    @foreach (var category in RatingCategoryInfo.GetAllCategories())
                    {
                        var average = ViewModel.CategoryAverages.GetValueOrDefault(category.Category, 0);
                        @if (average > 0)
                        {
                            <div class="rating-average-card">
                                <div class="rating-category-header">
                                    <span class="rating-emoji">@category.Emoji</span>
                                    <span class="rating-name">@category.DisplayName</span>
                                </div>
                                <div class="rating-value">@average.ToString("F1")</div>
                                <div class="rating-stars-display">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <span class="star @(i <= Math.Round(average) ? "filled" : "empty")">★</span>
                                    }
                                </div>
                            </div>
                        }
                    }
                </div>
            </section>
        }

        <!-- Top Rated Books -->
        <section class="top-rated-books-section compact">
            <h2>🏆 @L["Stats_TopRated"]</h2>

            <!-- Category Filter Chips (horizontally scrollable) -->
            <div class="category-filter-buttons" role="tablist" aria-label="@L["Stats_CategoryFilter"]">
                <button class="btn category-filter-btn @(selectedCategory == null ? "active" : "")"
                        @onclick="() => FilterByCategory(null)">
                    @L["Stats_Filter_All"]
                </button>
                @foreach (var category in RatingCategoryInfo.GetAllCategories())
                {
                    <button class="btn category-filter-btn @(selectedCategory == category.Category ? "active" : "")"
                            @onclick="() => FilterByCategory(category.Category)">
                        @category.Emoji @category.DisplayName
                    </button>
                }
            </div>

            @if (ViewModel.TopRatedBooks?.Any() == true)
            {
                <div class="top-books-list">
                    @{
                        int rank = 1;
                    }
                    @foreach (var bookRating in ViewModel.TopRatedBooks.Take(showAllTopBooks ? 6 : 3))
                    {
                        <div class="top-book-item" @key="bookRating.Book.Id">
                            <div class="book-info">
                                <div class="book-title"><span class="book-rank-inline">@rank.</span> @bookRating.Book.Title</div>
                                <div class="book-author">@bookRating.Book.Author</div>
                            </div>
                            <div class="book-rating-summary">
                                @if (selectedCategory.HasValue)
                                {
                                    var categoryRating = bookRating.Ratings.GetValueOrDefault(selectedCategory.Value);
                                    var categoryInfo = RatingCategoryInfo.GetAllCategories()
                                        .FirstOrDefault(c => c.Category == selectedCategory.Value);
                                    <div class="average-rating">@(categoryRating?.ToString() ?? "-") @(categoryInfo?.Emoji ?? "⭐")</div>
                                }
                                else
                                {
                                    <div class="average-rating">@bookRating.AverageRating.ToString("F1") ⭐</div>
                                }
                            </div>
                        </div>
                        rank++;
                    }
                </div>
                @if (ViewModel.TopRatedBooks.Count > 3)
                {
                    <button class="btn show-more-books-btn" @onclick="() => showAllTopBooks = !showAllTopBooks">
                        @(showAllTopBooks ? L["Stats_ShowLess"] : L["Stats_ShowMore"])
                    </button>
                }
            }
            else if (selectedCategory.HasValue)
            {
                <p class="advanced-stats-subtitle" style="text-align:center; padding:1rem 0;">
                    @L["Stats_NoRatedInCategory"]
                </p>
            }
        </section>

        <!-- Level Milestones (moved to bottom) -->
        @if (ViewModel.LevelMilestones.Any())
        {
            <section class="level-milestones-section">
                <h2>🎯 @L["Stats_LevelMilestones"]</h2>
                <div class="milestones-list">
                    @foreach (var milestone in ViewModel.LevelMilestones)
                    {
                        <div class="milestone-item @(milestone.IsCompleted ? "completed" : "") @(milestone.IsCurrent ? "current" : "")" @key="milestone.Level">
                            <div class="milestone-icon">
                                @if (milestone.IsCompleted)
                                {
                                    <span class="icon-completed">✓</span>
                                }
                                else if (milestone.IsCurrent)
                                {
                                    <span class="icon-current">🏆</span>
                                }
                                else
                                {
                                    <span class="icon-future">🔒</span>
                                }
                            </div>
                            <div class="milestone-content">
                                <div class="milestone-level">@L["Stats_Milestone_Level", milestone.Level]</div>
                                <div class="milestone-requirements">
                                    <span class="xp-req">@milestone.XpRequired XP</span>
                                    <span class="coins-reward">+@milestone.CoinsReward 💰</span>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </section>
        }
    }
</div>
}
else if (activeTab == 1)
{
    <LockedFeatureButton Feature="FeatureKey.StatsTrendsTab">
        <StatsTrends />
    </LockedFeatureButton>
}
else if (activeTab == 2)
{
    <LockedFeatureButton Feature="FeatureKey.StatsInsightsTab">
        <StatsAnalyses />
    </LockedFeatureButton>
}

@if (ViewModel.ShowShareModal)
{
    <div class="celebration-overlay" @onclick="CloseShareModal">
        <div class="share-modal-card" @onclick:stopPropagation="true">
            <h2>@L["Stats_Share_Title"]</h2>
            <p class="share-modal-subtitle">@L["Stats_Share_Subtitle"]</p>

            <div class="share-period-picker">
                <div class="period-type-tabs">
                    <button class="@("period-chip period-type" + (sharePeriodType == "alltime" ? " active" : ""))"
                            @onclick='() => SelectPeriodType("alltime")'>
                        @L["Stats_Period_AllTime"]
                    </button>
                    <button class="@("period-chip period-type" + (sharePeriodType == "year" ? " active" : ""))"
                            @onclick='() => SelectPeriodType("year")'>
                        @L["Stats_Period_Year"]
                    </button>
                    <button class="@("period-chip period-type" + (sharePeriodType == "month" ? " active" : ""))"
                            @onclick='() => SelectPeriodType("month")'>
                        @L["Stats_Period_Month"]
                    </button>
                </div>

                @if (sharePeriodType == "year" && ViewModel.AvailableShareYears.Any())
                {
                    <div class="period-sub-options">
                        @foreach (var year in ViewModel.AvailableShareYears)
                        {
                            var yearValue = year.ToString();
                            <button class="@("period-chip" + (ViewModel.SelectedSharePeriod == yearValue ? " active" : ""))"
                                    @onclick="() => ViewModel.SelectedSharePeriod = yearValue">
                                @yearValue
                            </button>
                        }
                    </div>
                }
                else if (sharePeriodType == "month" && ViewModel.AvailableShareMonths.Any())
                {
                    <div class="period-sub-options">
                        @foreach (var period in ViewModel.AvailableShareMonths)
                        {
                            var mDate = new DateTime(period.Year, period.Month, 1);
                            var monthValue = mDate.ToString("yyyy-MM");
                            var monthLabel = mDate.ToString("MMMM yyyy");
                            <button class="@("period-chip" + (ViewModel.SelectedSharePeriod == monthValue ? " active" : ""))"
                                    @onclick="() => ViewModel.SelectedSharePeriod = monthValue">
                                @monthLabel
                            </button>
                        }
                    </div>
                }
            </div>

            <button class="btn btn-primary share-modal-action"
                    @onclick="() => ViewModel.GenerateAndShareStatsCardCommand.ExecuteAsync(null)"
                    disabled="@ViewModel.IsGeneratingCard">
                @if (ViewModel.IsGeneratingCard)
                {
                    <span>@L["Stats_Generating"]</span>
                }
                else
                {
                    <span>📤 @L["Stats_CreateShare"]</span>
                }
            </button>

            <button class="btn btn-secondary share-modal-action"
                    @onclick="CloseShareModal">
                @L["Common_Cancel"]
            </button>
        </div>
    </div>
}

@code {
    private int activeTab = 0;

    private string TabClass(int tab) => tab == activeTab ? "stats-tab-btn active" : "stats-tab-btn";

    private void SetTab(int tab)
    {
        activeTab = tab;
        StateHasChanged();
    }

    private RatingCategory? selectedCategory = null;
    private bool showAllTopBooks = false;
    private string sharePeriodType = "alltime";
    private string? _currentUrl;

    private Func<Task<bool>>? _backHandler;
    private Func<Task<bool>>? _shareModalBackHandler;

    protected override async Task OnInitializedAsync()
    {
        Observe(ViewModel);
        NavigationManager.LocationChanged += OnLocationChanged;
        ViewModel.ShareCardReady += OnShareCardReady;

        // Register back handler to valid custom routing
        _backHandler = async () =>
        {
            // Navigate to bookshelf (root)
            NavigationManager.NavigateTo("/");
            return true;
        };
        BackButtonService.Register(_backHandler);

        try
        {
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Exception in Stats OnInitializedAsync: {ex}");
            // Don't rethrow — let the UI render with the ViewModel's ErrorMessage
        }
    }

    private void OnShareCardReady(byte[] cardBytes)
    {
        _ = InvokeAsync(async () =>
        {
            try
            {
                var fileName = $"share_stats_{DateTime.UtcNow:yyyyMMddHHmmss}.png";
                var filePath = Path.Combine(FileSystem.CacheDirectory, fileName);
                await File.WriteAllBytesAsync(filePath, cardBytes);
                await ShareService.ShareFileAsync(L["Stats_Share_FileName"], filePath, "image/png");
                await OnboardingService.TrackEventAsync(OnboardingEvent.StatsShared);
            }
            catch (Exception ex)
            {
                System.Diagnostics.Debug.WriteLine($"Failed to share stats card: {ex.Message}");
            }
        });
    }

    protected override async Task OnParametersSetAsync()
    {
        // Check if we navigated to this page
        var newUrl = NavigationManager.Uri;
        if (_currentUrl != newUrl)
        {
            _currentUrl = newUrl;
            await LoadDataAsync();
        }
    }

    private async Task LoadDataAsync()
    {
        selectedCategory = null;
        await ViewModel.LoadCommand.ExecuteAsync(null);
    }

    private async void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        // Reload when navigating to this page
        if (e.Location.Contains("/stats") || e.Location.Contains("/level-overview"))
        {
            await InvokeAsync(async () =>
            {
                await LoadDataAsync();
                StateHasChanged();
            });
        }
    }

    public override void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
        ViewModel.ShareCardReady -= OnShareCardReady;
        if (_backHandler != null)
        {
            BackButtonService.Unregister(_backHandler);
            _backHandler = null;
        }
        if (_shareModalBackHandler != null)
        {
            BackButtonService.Unregister(_shareModalBackHandler);
            _shareModalBackHandler = null;
        }
        base.Dispose();
    }

    private string FormatMinutes(int minutes)
    {
        if (minutes < 60) return $"{minutes}m";
        var hours = minutes / 60;
        var remainingMinutes = minutes % 60;
        return $"{hours}h {remainingMinutes}m";
    }

    private async Task FilterByCategory(RatingCategory? category)
    {
        selectedCategory = category;
        await ViewModel.FilterTopBooksByCategoryAsync(category);
        StateHasChanged();
    }

    private async Task OpenShareModal()
    {
        _shareModalBackHandler = async () =>
        {
            await InvokeAsync(() =>
            {
                CloseShareModal();
                StateHasChanged();
            });
            return true;
        };
        BackButtonService.Register(_shareModalBackHandler);

        ViewModel.ShowShareModal = true;
        sharePeriodType = "alltime";
        ViewModel.SelectedSharePeriod = L["Stats_Period_AllTime"];
        await ViewModel.LoadActivePeriodsAsync();
        StateHasChanged();
    }

    private void CloseShareModal()
    {
        if (_shareModalBackHandler != null)
        {
            BackButtonService.Unregister(_shareModalBackHandler);
            _shareModalBackHandler = null;
        }
        ViewModel.ShowShareModal = false;
    }

    private void SelectPeriodType(string type)
    {
        sharePeriodType = type;
        ViewModel.SelectedSharePeriod = type switch
        {
            "year" when ViewModel.AvailableShareYears.Count > 0
                => ViewModel.AvailableShareYears[0].ToString(),
            "month" when ViewModel.AvailableShareMonths.Count > 0
                => new DateTime(ViewModel.AvailableShareMonths[0].Year, ViewModel.AvailableShareMonths[0].Month, 1).ToString("yyyy-MM"),
            _ => L["Stats_Period_AllTime"]
        };
    }

    private string GetPlantBoostWidth(PlantBoostInfo plant)
    {
        if (ViewModel.TotalPlantBoost <= 0m)
        {
            return "0%";
        }

        var width = (plant.BoostPercentage / ViewModel.TotalPlantBoost) * 100m;
        return $"{width.ToString("F1", CultureInfo.InvariantCulture)}%";
    }
}
