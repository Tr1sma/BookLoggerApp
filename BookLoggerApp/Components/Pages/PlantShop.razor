@page "/shop"
@using BookLoggerApp.Core.ViewModels
@using BookLoggerApp.Core.Models
@using BookLoggerApp.Core.Resources
@using BookLoggerApp.Core.Entitlements
@using BookLoggerApp.Components.Shared
@using Microsoft.Extensions.Localization
@inject PlantShopViewModel ViewModel
@inject DecorationShopViewModel DecorationVM
@inject NavigationManager Navigation
@inject BookLoggerApp.Core.Services.Abstractions.IBackButtonService BackButtonService
@inject BookLoggerApp.Core.Services.Abstractions.IOnboardingService OnboardingService
@inject IStringLocalizer<AppResources> L
@implements IDisposable

<PageTitle>@L["PageTitle_Shop"] - BookHeart</PageTitle>


<AnalyticsScreenTracker Screen="@BookLoggerApp.Core.Services.Analytics.ScreenNames.PlantShop" />
<div class="plant-shop-container">
    <!-- Header -->
    <div class="shop-header">
        <h1>🛍️ @L["Shop_Title"]</h1>
        <div class="user-stats">
            <div class="stat-coin">
                <span class="coin-icon">🪙</span>
                <span class="coin-count">@(activeTab == "plants" ? ViewModel.UserCoins : DecorationVM.UserCoins) @L["Shop_Coins"]</span>
            </div>
            <div class="stat-level">
                <span>@L["Shop_LevelPrefix"] @(activeTab == "plants" ? ViewModel.UserLevel : DecorationVM.UserLevel)</span>
            </div>
        </div>
    </div>

    <!-- Tab Bar -->
    <div class="shop-tabs">
        <button class="shop-tab-btn @(activeTab == "plants" ? "active" : "")"
                @onclick='() => SwitchTab("plants")'>
            🌱 @L["Shop_Tab_Plants"]
        </button>
        <button class="shop-tab-btn @(activeTab == "decorations" ? "active" : "")"
                @onclick='() => SwitchTab("decorations")'>
            🕯️ @L["Shop_Tab_Decorations"]
        </button>
    </div>

    @* ===== PLANTS TAB ===== *@
    @if (activeTab == "plants")
    {
        <!-- Description -->
        <div class="shop-description">
            <p>🌿 @L["Shop_Plants_Description"]</p>
        </div>

        @if (ViewModel.IsBusy)
        {
            <div class="loading">@L["Shop_Loading"]</div>
        }
        else if (!string.IsNullOrEmpty(ViewModel.ErrorMessage))
        {
            <div class="alert alert-danger">
                @ViewModel.ErrorMessage
                <button class="btn-close-alert" @onclick="() => ViewModel.ErrorMessage = null">×</button>
            </div>
        }
        else
        {
            <!-- Shop Grid -->
            <div class="shop-grid">
                @foreach (var species in ViewModel.AvailableSpecies)
                {
                    FeatureKey? plantTierFeature = GetPlantTierFeature(species);
                    if (plantTierFeature is null)
                    {
                        <PlantShopCard
                            Species="@species"
                            UserCoins="@ViewModel.UserCoins"
                            UserLevel="@ViewModel.UserLevel"
                            CurrentPrice="@ViewModel.GetDynamicPrice(species.Id)"
                            IsSelected="@(ViewModel.SelectedSpecies?.Id == species.Id)"
                            OnSelect="() => SelectSpecies(species)" />
                    }
                    else
                    {
                        <LockedFeatureButton Feature="plantTierFeature.Value">
                            <PlantShopCard
                                Species="@species"
                                UserCoins="@ViewModel.UserCoins"
                                UserLevel="@ViewModel.UserLevel"
                                CurrentPrice="@ViewModel.GetDynamicPrice(species.Id)"
                                IsSelected="@(ViewModel.SelectedSpecies?.Id == species.Id)"
                                OnSelect="() => SelectSpecies(species)" />
                        </LockedFeatureButton>
                    }
                }
            </div>

            @if (!ViewModel.AvailableSpecies.Any())
            {
                <div class="empty-state">
                    <h3>@L["Shop_Plants_Empty_Title"]</h3>
                    <p>@L["Shop_Plants_Empty_Body"]</p>
                </div>
            }
        }

        <!-- Plant Purchase Modal -->
        @if (ViewModel.SelectedSpecies != null)
        {
            <div class="purchase-modal-overlay" @onclick="ClearSelection">
                <div class="purchase-modal" @onclick:stopPropagation="true">
                    <div class="modal-header">
                        <h2>@L["Shop_Purchase_Prefix"] <span class="purchase-plant-name">@ViewModel.SelectedSpecies.Name</span></h2>
                        <button class="btn-close" @onclick="ClearSelection">×</button>
                    </div>

                    <div class="modal-body">
                        <div class="plant-preview">
                            <img src="@ViewModel.SelectedSpecies.ImagePath" alt="@ViewModel.SelectedSpecies.Name" />
                        </div>

                        <div class="plant-details">
                            <p class="plant-description">@ViewModel.SelectedSpecies.Description</p>

                            <div class="plant-stats-grid">
                                <div class="stat-item">
                                    <label>@L["Shop_Plants_MaxLevel"]</label>
                                    <span>@ViewModel.SelectedSpecies.MaxLevel</span>
                                </div>
                                <div class="stat-item">
                                    <label>@L["Shop_Plants_WaterInterval"]</label>
                                    <span>@L["Shop_Plants_EveryDays", ViewModel.SelectedSpecies.WaterIntervalDays]</span>
                                </div>
                                <div class="stat-item">
                                    <label>@L["Shop_Plants_GrowthRate"]</label>
                                    <span>@ViewModel.SelectedSpecies.GrowthRate.ToString("0.0")x</span>
                                </div>
                                <div class="stat-item">
                                    <label>@L["Shop_Plants_Cost"]</label>
                                    <span>🪙 @ViewModel.GetDynamicPrice(ViewModel.SelectedSpecies.Id)</span>
                                </div>
                            </div>

                            @if (!string.IsNullOrEmpty(ViewModel.SelectedSpecies.SpecialAbilityKey))
                            {
                                <div class="ability-callout">
                                    ✨ <strong>@L["Shop_SpecialAbility"]:</strong> @GetAbilityDescription(ViewModel.SelectedSpecies.SpecialAbilityKey)
                                </div>
                            }

                            <div class="name-input-group">
                                <label>@L["Shop_Plants_NameLabel"]</label>
                                <input type="text"
                                       class="plant-name-input"
                                       placeholder="@(L["Shop_Plants_NamePlaceholder", ViewModel.SelectedSpecies.Name].Value)"
                                       @bind="ViewModel.NewPlantName"
                                       @bind:event="oninput"
                                       maxlength="100" />
                            </div>
                        </div>
                    </div>

                    <div class="modal-footer">
                        <button class="btn btn-secondary" @onclick="ClearSelection">
                            @L["Common_Cancel"]
                        </button>
                        <button class="btn btn-primary"
                                @onclick="HandlePlantPurchaseAsync"
                                disabled="@(ViewModel.IsBusy || ViewModel.UserCoins < ViewModel.GetDynamicPrice(ViewModel.SelectedSpecies.Id))">
                            @if (ViewModel.UserCoins >= ViewModel.GetDynamicPrice(ViewModel.SelectedSpecies.Id))
                            {
                                <span>@L["Shop_PurchaseForCoins", ViewModel.GetDynamicPrice(ViewModel.SelectedSpecies.Id)]</span>
                            }
                            else
                            {
                                <span>@L["Shop_NotEnoughCoins"]</span>
                            }
                        </button>
                    </div>
                </div>
            </div>
        }

        <div class="info-box">
            <h4>📚 @L["Shop_HowPlantsGrow_Title"]</h4>
            <ul>
                <li>@((MarkupString)L["Shop_HowPlantsGrow_Bullet1"].Value)</li>
                <li>@((MarkupString)L["Shop_HowPlantsGrow_Bullet2"].Value)</li>
                <li>@((MarkupString)L["Shop_HowPlantsGrow_Bullet3"].Value)</li>
                <li>@((MarkupString)L["Shop_HowPlantsGrow_Bullet4"].Value)</li>
                <li>@((MarkupString)L["Shop_HowPlantsGrow_Bullet5"].Value)</li>
            </ul>
        </div>
    }

    @* ===== DECORATIONS TAB ===== *@
    @if (activeTab == "decorations")
    {
        <!-- Description -->
        <div class="shop-description">
            <p>🕯️ @L["Shop_Decorations_Description"]</p>
        </div>

        @if (DecorationVM.IsBusy)
        {
            <div class="loading">@L["Shop_Decorations_Loading"]</div>
        }
        else if (!string.IsNullOrEmpty(DecorationVM.ErrorMessage))
        {
            <div class="alert alert-danger">
                @DecorationVM.ErrorMessage
                <button class="btn-close-alert" @onclick="() => DecorationVM.ErrorMessage = null">×</button>
            </div>
        }
        else
        {
            <!-- Decoration Grid -->
            <div class="shop-grid">
                @foreach (var item in DecorationVM.AllDecorations)
                {
                    FeatureKey? decoTierFeature = GetDecorationTierFeature(item);
                    if (decoTierFeature is null)
                    {
                        <DecorationShopCard
                            Item="@item"
                            UserCoins="@DecorationVM.UserCoins"
                            UserLevel="@DecorationVM.UserLevel"
                            IsSelected="@(DecorationVM.SelectedDecoration?.Id == item.Id)"
                            OnSelect="() => SelectDecoration(item)" />
                    }
                    else
                    {
                        <LockedFeatureButton Feature="decoTierFeature.Value">
                            <DecorationShopCard
                                Item="@item"
                                UserCoins="@DecorationVM.UserCoins"
                                UserLevel="@DecorationVM.UserLevel"
                                IsSelected="@(DecorationVM.SelectedDecoration?.Id == item.Id)"
                                OnSelect="() => SelectDecoration(item)" />
                        </LockedFeatureButton>
                    }
                }
            </div>

            @if (!DecorationVM.AllDecorations.Any())
            {
                <div class="empty-state">
                    <h3>@L["Shop_Decorations_Empty_Title"]</h3>
                    <p>@L["Shop_Decorations_Empty_Body"]</p>
                </div>
            }
        }

        <!-- Decoration Purchase Modal -->
        @if (DecorationVM.SelectedDecoration != null)
        {
            <div class="purchase-modal-overlay" @onclick="ClearDecorationSelection">
                <div class="purchase-modal" @onclick:stopPropagation="true">
                    <div class="modal-header">
                        <h2>@L["Shop_Purchase_Prefix"] <span class="purchase-plant-name">@DecorationVM.SelectedDecoration.Name</span></h2>
                        <button class="btn-close" @onclick="ClearDecorationSelection">×</button>
                    </div>

                    <div class="modal-body">
                        <div class="plant-preview">
                            <img src="@DecorationVM.SelectedDecoration.ImagePath" alt="@DecorationVM.SelectedDecoration.Name" />
                        </div>

                        <div class="plant-details">
                            <p class="plant-description">@DecorationVM.SelectedDecoration.Description</p>

                            <div class="plant-stats-grid">
                                <div class="stat-item">
                                    <label>@L["Shop_Plants_Cost"]</label>
                                    <span>🪙 @DecorationVM.SelectedDecoration.Cost</span>
                                </div>
                                <div class="stat-item">
                                    <label>@L["Shop_UnlockLevel"]</label>
                                    <span>@L["Stats_LevelAbbrev"] @DecorationVM.SelectedDecoration.UnlockLevel</span>
                                </div>
                            </div>

                            @if (!string.IsNullOrEmpty(DecorationVM.SelectedDecoration.SpecialAbilityKey))
                            {
                                <div class="ability-callout">
                                    ✨ <strong>@L["Shop_SpecialAbility"]:</strong> @GetAbilityDescription(DecorationVM.SelectedDecoration.SpecialAbilityKey)
                                </div>
                            }
                        </div>
                    </div>

                    <div class="modal-footer">
                        <button class="btn btn-secondary" @onclick="ClearDecorationSelection">
                            @L["Common_Cancel"]
                        </button>
                        <button class="btn btn-primary"
                                @onclick="HandleDecorationPurchaseAsync"
                                disabled="@(DecorationVM.IsBusy || DecorationVM.UserCoins < DecorationVM.SelectedDecoration.Cost || DecorationVM.UserLevel < DecorationVM.SelectedDecoration.UnlockLevel)">
                            @if (DecorationVM.UserLevel < DecorationVM.SelectedDecoration.UnlockLevel)
                            {
                                <span>@L["Shop_RequiresLevel", DecorationVM.SelectedDecoration.UnlockLevel]</span>
                            }
                            else if (DecorationVM.UserCoins >= DecorationVM.SelectedDecoration.Cost)
                            {
                                <span>@L["Shop_PurchaseForCoins", DecorationVM.SelectedDecoration.Cost]</span>
                            }
                            else
                            {
                                <span>@L["Shop_NotEnoughCoins"]</span>
                            }
                        </button>
                    </div>
                </div>
            </div>
        }
    }
</div>

@code {
    private string activeTab = "plants";
    private Func<Task<bool>>? _navBackHandler;
    private Func<Task<bool>>? _modalBackHandler;

    protected override async Task OnInitializedAsync()
    {
        _navBackHandler = async () =>
        {
            Navigation.NavigateTo("/");
            return true;
        };
        BackButtonService.Register(_navBackHandler);

        await ViewModel.LoadCommand.ExecuteAsync(null);
        await DecorationVM.LoadCommand.ExecuteAsync(null);
    }

    protected override async Task OnParametersSetAsync()
    {
        if (ViewModel.AvailableSpecies.Any())
        {
            await ViewModel.LoadCommand.ExecuteAsync(null);
        }
        if (DecorationVM.AllDecorations.Any())
        {
            await DecorationVM.LoadCommand.ExecuteAsync(null);
        }
    }

    private async Task SwitchTab(string tab)
    {
        activeTab = tab;
        if (tab == "decorations")
            await DecorationVM.LoadCommand.ExecuteAsync(null);
        else
            await ViewModel.LoadCommand.ExecuteAsync(null);
    }

    // ===== Plant handlers =====

    private async Task HandlePlantPurchaseAsync()
    {
        if (ViewModel.SelectedSpecies != null)
        {
            await ViewModel.PurchasePlantCommand.ExecuteAsync(ViewModel.SelectedSpecies.Id);

            if (string.IsNullOrEmpty(ViewModel.ErrorMessage))
            {
                await OnboardingService.TrackEventAsync(OnboardingEvent.PlantPurchased);
                Navigation.NavigateTo("/bookshelf");
            }
            else
            {
                StateHasChanged();
            }
        }
    }

    private void SelectSpecies(PlantSpecies species)
    {
        ViewModel.SelectSpeciesCommand.Execute(species);

        _modalBackHandler = async () =>
        {
            ClearSelection();
            return true;
        };
        BackButtonService.Register(_modalBackHandler);
    }

    private void ClearSelection()
    {
        ViewModel.ClearSelectionCommand.Execute(null);
        UnregisterModalBack();
    }

    // ===== Decoration handlers =====

    private async Task HandleDecorationPurchaseAsync()
    {
        if (DecorationVM.SelectedDecoration != null)
        {
            await DecorationVM.PurchaseDecorationCommand.ExecuteAsync(DecorationVM.SelectedDecoration.Id);

            if (string.IsNullOrEmpty(DecorationVM.ErrorMessage))
            {
                Navigation.NavigateTo("/bookshelf");
            }
            else
            {
                StateHasChanged();
            }
        }
    }

    private void SelectDecoration(ShopItem item)
    {
        DecorationVM.SelectDecorationCommand.Execute(item);

        _modalBackHandler = async () =>
        {
            ClearDecorationSelection();
            return true;
        };
        BackButtonService.Register(_modalBackHandler);
    }

    private void ClearDecorationSelection()
    {
        DecorationVM.ClearSelectionCommand.Execute(null);
        UnregisterModalBack();
    }

    // ===== Common =====

    private void UnregisterModalBack()
    {
        if (_modalBackHandler != null)
        {
            BackButtonService.Unregister(_modalBackHandler);
            _modalBackHandler = null;
        }
    }

    public void Dispose()
    {
        if (_navBackHandler != null)
        {
            BackButtonService.Unregister(_navBackHandler);
            _navBackHandler = null;
        }
        UnregisterModalBack();
    }

    private static FeatureKey? GetPlantTierFeature(PlantSpecies species)
    {
        if (species.IsPrestigeTier)
        {
            return FeatureKey.PrestigePlants;
        }
        if (species.IsFreeTier)
        {
            return null;
        }
        return FeatureKey.StandardPlantsAndDecorations;
    }

    private static FeatureKey? GetDecorationTierFeature(ShopItem item)
    {
        if (item.IsUltimateTier)
        {
            return FeatureKey.UltimateDecorations;
        }
        if (item.IsFreeTier)
        {
            return null;
        }
        return FeatureKey.StandardPlantsAndDecorations;
    }

    private string GetAbilityDescription(string? abilityKey) => abilityKey switch
    {
        SpecialAbilityKeys.StreakGuardian => L["Shop_Ability_StreakGuardian"],
        SpecialAbilityKeys.EternalPhoenix => L["Shop_Ability_EternalPhoenix"],
        SpecialAbilityKeys.StoryHeart    => L["Shop_Ability_StoryHeart"],
        _ => string.Empty
    };
}
