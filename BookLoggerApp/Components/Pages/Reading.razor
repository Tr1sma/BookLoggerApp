@page "/reading/{SessionId:guid}"
@using BookLoggerApp.Core.ViewModels
@using BookLoggerApp.Core.Models
@using BookLoggerApp.Core.Services.Abstractions
@using BookLoggerApp.Components.Shared
@inject ReadingViewModel ViewModel
@inject ITimerStateService TimerStateService
@inject Microsoft.AspNetCore.Components.NavigationManager Navigation
@inject IReviewPromptService ReviewPromptService
@inject IShareService ShareService
@inject BookLoggerApp.Core.Services.Abstractions.IWidgetUpdateService WidgetUpdateService
@inject BookLoggerApp.Core.Services.Abstractions.IBackButtonService BackButtonService
@inject IOnboardingService OnboardingService
@implements IDisposable

<PageTitle>Reading - BookHeart</PageTitle>


<AnalyticsScreenTracker Screen="@BookLoggerApp.Core.Services.Analytics.ScreenNames.Reading" />
<div class="reading-container">
    @if (ViewModel.IsBusy)
    {
        <div class="loading">Loading session...</div>
    }
    else if (!string.IsNullOrEmpty(ViewModel.ErrorMessage))
    {
        <div class="alert alert-danger">@ViewModel.ErrorMessage</div>
    }
    else if (ViewModel.Session == null)
    {
        <div class="empty-state">
            <h2>No active reading session</h2>
            <p>Start reading a book to begin a session.</p>
            <button class="btn btn-primary" @onclick="NavigateToBookshelf">Browse Bookshelf</button>
        </div>
    }
    else if (ViewModel.Book == null)
    {
        <div class="empty-state">
            <h2>Book not found</h2>
            <p>The book for this reading session could not be loaded.</p>
        </div>
    }
    else
    {
        <!-- Book Info -->
        <div class="reading-header">
            <div class="book-info">
                <h1>@ViewModel.Book.Title</h1>
                <p class="author">by @ViewModel.Book.Author</p>
            </div>
            <button class="btn btn-secondary" @onclick="NavigateToBook">View Book Details</button>
        </div>

        <!-- Timer & Stats -->
        <div class="reading-stats">
            <div class="stat-item timer">
                <label>Reading Time</label>
                <div class="timer-display">
                    <span class="timer-value">@FormatTime(ViewModel.ElapsedTime)</span>
                </div>
                <div class="timer-controls">
                    @if (ViewModel.IsPaused)
                    {
                        <button class="btn btn-primary" @onclick="() => ViewModel.ResumeCommand.Execute(null)">▶ Resume</button>
                    }
                    else
                    {
                        <button class="btn btn-secondary" @onclick="() => ViewModel.PauseCommand.Execute(null)">⏸ Pause</button>
                    }
                </div>
            </div>

            <div class="stat-item xp">
                <label>XP Earned</label>
                <div class="xp-display">
                    <span class="xp-value">@ViewModel.XpEarned</span>
                </div>
            </div>

            <div class="stat-item pages">
                <label>Current Page</label>
                <div class="page-input-group">
                    <input type="number" 
                           class="page-input" 
                           value="@ViewModel.CurrentPage"
                           @onchange="@(async (ChangeEventArgs e) => { if (int.TryParse(e.Value?.ToString(), out int page)) { ViewModel.CurrentPage = page; await HandlePageChange(); } })"
                           min="0" 
                           max="@(ViewModel.Book.PageCount ?? int.MaxValue)" />
                    @if (ViewModel.Book.PageCount.HasValue)
                    {
                        <span class="page-total">/ @ViewModel.Book.PageCount</span>
                    }
                </div>
                @if (ViewModel.Book.PageCount.HasValue)
                {
                    <div class="progress-bar">
                        <div class="progress-fill" style="width: @ViewModel.Book.ProgressPercentage%"></div>
                    </div>
                    <p class="progress-text">@ViewModel.Book.ProgressPercentage% complete</p>
                }
            </div>
        </div>

        <!-- Session Summary -->
        <div class="session-summary">
            <h2>Session Summary</h2>
            <div class="summary-grid">
                <div class="summary-item">
                    <label>Started</label>
                    <p>@ViewModel.SessionStartTime.ToString("g")</p>
                </div>
                <div class="summary-item">
                    <label>Pages Read</label>
                    <p>@(ViewModel.CurrentPage - ViewModel.StartPage)</p>
                </div>
                <div class="summary-item">
                    <label>Estimated Time</label>
                    <p>@FormatTime(ViewModel.ElapsedTime)</p>
                </div>
            </div>
        </div>

        <!-- Actions -->
        <div class="reading-actions">
            <button class="btn btn-primary btn-large" @onclick="HandleEndSession" disabled="@ViewModel.IsBusy">
                ✓ End Session
            </button>
            <button class="btn btn-secondary" @onclick="NavigateToBook">Cancel</button>
        </div>

        <!-- Fullscreen Option (Optional) -->
        <div class="fullscreen-hint">
            <p>💡 Focus on reading - this session is being tracked automatically</p>
        </div>
    }
</div>

<!-- Celebration Overlays -->
@if (ViewModel.ShowSessionCelebration && ViewModel.SessionProgressionResult != null)
{
    <SessionCompleteCelebration
        Result="@ViewModel.SessionProgressionResult"
        StreakRescuedByGuardian="@ViewModel.StreakRescuedByGuardian"
        StoryHeartCoinBonus="@ViewModel.StoryHeartCoinBonus"
        StoryHeartFirstOfDayBonusXp="@ViewModel.StoryHeartFirstOfDayBonusXp"
        OnClose="@HandleSessionCelebrationClose" />
}

@if (ViewModel.ShowStreakCelebration && ViewModel.SessionProgressionResult != null)
{
    <StreakCelebration
        StreakDays="@ViewModel.SessionProgressionResult.StreakDays"
        BonusXp="@ViewModel.SessionProgressionResult.StreakBonusXp"
        OnClose="@HandleStreakCelebrationClose" />
}

@if (ViewModel.ShowLevelUpCelebration && ViewModel.LevelUpResult != null)
{
    <LevelUpCelebration
        Result="@ViewModel.LevelUpResult"
        OnClose="@HandleLevelUpCelebrationClose" />
}

@if (ViewModel.ShowBookCompletionCelebration && ViewModel.Book != null)
{
    <BookCompletionCelebration
        IsVisible="true"
        Book="@ViewModel.Book"
        TotalXpEarned="@(ViewModel.SessionProgressionResult?.XpEarned ?? 0)"
        ShowShareButton="true"
        IsGeneratingCard="@ViewModel.IsGeneratingBookCard"
        OnClose="@HandleBookCompletionCelebrationClose"
        OnShareBook="@HandleShareBook" />
}

@if (_showReviewPrompt)
{
    <ReviewPromptModal
        IsVisible="@_showReviewPrompt"
        OnClose="@HandleReviewPromptClose"
        OnNeverAskAgain="@HandleNeverAskAgainAsync" />
}

@code {
    [Parameter] public Guid SessionId { get; set; }
    private bool _showReviewPrompt;
    private Func<Task<bool>>? _navBackHandler;
    private Func<Task<bool>>? _sessionCelebrationBackHandler;
    private Func<Task<bool>>? _streakCelebrationBackHandler;
    private Func<Task<bool>>? _levelUpCelebrationBackHandler;
    private Func<Task<bool>>? _bookCompletionCelebrationBackHandler;
    private Func<Task<bool>>? _reviewPromptBackHandler;

    protected override async Task OnInitializedAsync()
    {
        _navBackHandler = async () =>
        {
            NavigateToBook();
            return true;
        };
        BackButtonService.Register(_navBackHandler);

        TimerStateService.AppResumed += OnAppResumed;
        ViewModel.BookShareCardReady += OnBookShareCardReady;
        await ViewModel.LoadCommand.ExecuteAsync(SessionId);
    }

    protected override async Task OnParametersSetAsync()
    {
        if (SessionId != Guid.Empty)
        {
            await ViewModel.LoadCommand.ExecuteAsync(SessionId);
        }
    }

    private void OnAppResumed()
    {
        // Force UI refresh when app returns from background
        InvokeAsync(StateHasChanged);
    }

    private async Task HandlePageChange()
    {
        await ViewModel.UpdatePageCommand.ExecuteAsync((int?)ViewModel.CurrentPage);
    }

    private async Task HandleEndSession()
    {
        var bookId = ViewModel.Book?.Id;
        await ViewModel.EndSessionCommand.ExecuteAsync(null);
        WidgetUpdateService.NotifyDataChanged();

        if (string.IsNullOrWhiteSpace(ViewModel.ErrorMessage))
        {
            await OnboardingService.TrackEventAsync(OnboardingEvent.ReadingSessionLogged, bookId);
        }

        // Register celebration handler for whichever celebration shows first
        if (ViewModel.ShowSessionCelebration)
        {
            _sessionCelebrationBackHandler = async () =>
            {
                await HandleSessionCelebrationClose();
                return true;
            };
            BackButtonService.Register(_sessionCelebrationBackHandler);
        }
        else if (ViewModel.ShowLevelUpCelebration)
        {
            _levelUpCelebrationBackHandler = async () =>
            {
                await HandleLevelUpCelebrationClose();
                return true;
            };
            BackButtonService.Register(_levelUpCelebrationBackHandler);
        }
        else if (ViewModel.ShowBookCompletionCelebration)
        {
            _bookCompletionCelebrationBackHandler = async () =>
            {
                await HandleBookCompletionCelebrationClose();
                return true;
            };
            BackButtonService.Register(_bookCompletionCelebrationBackHandler);
        }
    }

    private async Task HandleSessionCelebrationClose()
    {
        // Guard against double-fire (rapid tap, or tap + back-button race before re-render).
        // Without this, a second invocation re-registers a duplicate back-button handler for
        // the next celebration in the chain, which later causes a back press to trigger a
        // ghost close on an already-dismissed celebration.
        if (!ViewModel.ShowSessionCelebration) return;

        if (_sessionCelebrationBackHandler != null)
        {
            BackButtonService.Unregister(_sessionCelebrationBackHandler);
            _sessionCelebrationBackHandler = null;
        }

        var shouldShowReviewPrompt = ViewModel.HasReviewPromptMoment;
        await ViewModel.OnSessionCelebrationClose();
        StateHasChanged();

        if (ViewModel.ShowStreakCelebration)
        {
            _streakCelebrationBackHandler = async () =>
            {
                await HandleStreakCelebrationClose();
                return true;
            };
            BackButtonService.Register(_streakCelebrationBackHandler);
        }
        else if (ViewModel.ShowLevelUpCelebration)
        {
            _levelUpCelebrationBackHandler = async () =>
            {
                await HandleLevelUpCelebrationClose();
                return true;
            };
            BackButtonService.Register(_levelUpCelebrationBackHandler);
        }
        else if (ViewModel.ShowBookCompletionCelebration)
        {
            _bookCompletionCelebrationBackHandler = async () =>
            {
                await HandleBookCompletionCelebrationClose();
                return true;
            };
            BackButtonService.Register(_bookCompletionCelebrationBackHandler);
        }
        else
        {
            await TryShowReviewPromptOrNavigateAsync(shouldShowReviewPrompt);
        }
    }

    private async Task HandleStreakCelebrationClose()
    {
        if (!ViewModel.ShowStreakCelebration) return; // idempotency guard — see HandleSessionCelebrationClose

        if (_streakCelebrationBackHandler != null)
        {
            BackButtonService.Unregister(_streakCelebrationBackHandler);
            _streakCelebrationBackHandler = null;
        }

        var shouldShowReviewPrompt = ViewModel.HasReviewPromptMoment;
        await ViewModel.OnStreakCelebrationClose();
        StateHasChanged();

        if (ViewModel.ShowLevelUpCelebration)
        {
            _levelUpCelebrationBackHandler = async () =>
            {
                await HandleLevelUpCelebrationClose();
                return true;
            };
            BackButtonService.Register(_levelUpCelebrationBackHandler);
        }
        else if (ViewModel.ShowBookCompletionCelebration)
        {
            _bookCompletionCelebrationBackHandler = async () =>
            {
                await HandleBookCompletionCelebrationClose();
                return true;
            };
            BackButtonService.Register(_bookCompletionCelebrationBackHandler);
        }
        else
        {
            await TryShowReviewPromptOrNavigateAsync(shouldShowReviewPrompt);
        }
    }

    private async Task HandleLevelUpCelebrationClose()
    {
        if (!ViewModel.ShowLevelUpCelebration) return; // idempotency guard — see HandleSessionCelebrationClose

        if (_levelUpCelebrationBackHandler != null)
        {
            BackButtonService.Unregister(_levelUpCelebrationBackHandler);
            _levelUpCelebrationBackHandler = null;
        }

        var shouldShowReviewPrompt = ViewModel.HasReviewPromptMoment;
        await ViewModel.OnLevelUpCelebrationClose();
        StateHasChanged();

        if (ViewModel.ShowBookCompletionCelebration)
        {
            _bookCompletionCelebrationBackHandler = async () =>
            {
                await HandleBookCompletionCelebrationClose();
                return true;
            };
            BackButtonService.Register(_bookCompletionCelebrationBackHandler);
        }
        else
        {
            await TryShowReviewPromptOrNavigateAsync(shouldShowReviewPrompt);
        }
    }

    private async Task HandleBookCompletionCelebrationClose()
    {
        if (!ViewModel.ShowBookCompletionCelebration) return; // idempotency guard — see HandleSessionCelebrationClose

        if (_bookCompletionCelebrationBackHandler != null)
        {
            BackButtonService.Unregister(_bookCompletionCelebrationBackHandler);
            _bookCompletionCelebrationBackHandler = null;
        }

        var shouldShowReviewPrompt = ViewModel.HasReviewPromptMoment;
        await ViewModel.OnBookCompletionCelebrationClose();
        StateHasChanged();

        if (ViewModel.ShowStreakCelebration)
        {
            _streakCelebrationBackHandler = async () =>
            {
                await HandleStreakCelebrationClose();
                return true;
            };
            BackButtonService.Register(_streakCelebrationBackHandler);
        }
        else
        {
            await TryShowReviewPromptOrNavigateAsync(shouldShowReviewPrompt);
        }
    }

    private async Task HandleShareBook()
    {
        await ViewModel.GenerateAndShareBookCardCommand.ExecuteAsync(null);
    }

    private async void OnBookShareCardReady(byte[] cardBytes)
    {
        try
        {
            var fileName = $"bookheart_recommendation_{DateTime.Now:yyyyMMdd_HHmmss}.png";
            var filePath = Path.Combine(FileSystem.CacheDirectory, fileName);
            await File.WriteAllBytesAsync(filePath, cardBytes);
            await ShareService.ShareFileAsync("Book Recommendation", filePath, "image/png");

            if (ViewModel.Book?.Status == ReadingStatus.Completed)
            {
                await OnboardingService.TrackEventAsync(OnboardingEvent.BookShared, ViewModel.Book.Id);
            }
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Failed to share book card: {ex.Message}");
        }

        await InvokeAsync(StateHasChanged);
    }

    private Task HandleReviewPromptClose()
    {
        if (_reviewPromptBackHandler != null)
        {
            BackButtonService.Unregister(_reviewPromptBackHandler);
            _reviewPromptBackHandler = null;
        }
        _showReviewPrompt = false;
        Navigation.NavigateTo("/bookshelf");
        return Task.CompletedTask;
    }

    private async Task HandleNeverAskAgainAsync()
    {
        if (_reviewPromptBackHandler != null)
        {
            BackButtonService.Unregister(_reviewPromptBackHandler);
            _reviewPromptBackHandler = null;
        }
        _showReviewPrompt = false;
        await ReviewPromptService.DisablePromptAsync();
        Navigation.NavigateTo("/bookshelf");
    }

    private async Task TryShowReviewPromptOrNavigateAsync(bool shouldShowReviewPrompt)
    {
        if (shouldShowReviewPrompt && await ReviewPromptService.TryStartPromptAsync())
        {
            _reviewPromptBackHandler = async () =>
            {
                await HandleReviewPromptClose();
                return true;
            };
            BackButtonService.Register(_reviewPromptBackHandler);

            _showReviewPrompt = true;
            return;
        }

        Navigation.NavigateTo("/bookshelf");
    }

    private void NavigateToBook()
    {
        if (ViewModel.Book != null)
        {
            Navigation.NavigateTo($"/books/{ViewModel.Book.Id}");
        }
        else
        {
            Navigation.NavigateTo("/bookshelf");
        }
    }

    private void NavigateToBookshelf()
    {
        Navigation.NavigateTo("/bookshelf");
    }

    private string FormatTime(TimeSpan timeSpan)
    {
        if (timeSpan.TotalHours >= 1)
        {
            return $"{(int)timeSpan.TotalHours}h {timeSpan.Minutes}m {timeSpan.Seconds}s";
        }
        return $"{timeSpan.Minutes}m {timeSpan.Seconds}s";
    }

    public void Dispose()
    {
        if (_navBackHandler != null)
        {
            BackButtonService.Unregister(_navBackHandler);
            _navBackHandler = null;
        }
        if (_sessionCelebrationBackHandler != null)
        {
            BackButtonService.Unregister(_sessionCelebrationBackHandler);
            _sessionCelebrationBackHandler = null;
        }
        if (_streakCelebrationBackHandler != null)
        {
            BackButtonService.Unregister(_streakCelebrationBackHandler);
            _streakCelebrationBackHandler = null;
        }
        if (_levelUpCelebrationBackHandler != null)
        {
            BackButtonService.Unregister(_levelUpCelebrationBackHandler);
            _levelUpCelebrationBackHandler = null;
        }
        if (_bookCompletionCelebrationBackHandler != null)
        {
            BackButtonService.Unregister(_bookCompletionCelebrationBackHandler);
            _bookCompletionCelebrationBackHandler = null;
        }
        if (_reviewPromptBackHandler != null)
        {
            BackButtonService.Unregister(_reviewPromptBackHandler);
            _reviewPromptBackHandler = null;
        }
        TimerStateService.AppResumed -= OnAppResumed;
        ViewModel.BookShareCardReady -= OnBookShareCardReady;
        ViewModel.Dispose();
    }
}

