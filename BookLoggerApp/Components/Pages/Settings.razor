@page "/settings"
@using BookLoggerApp.Core.Entitlements
@using BookLoggerApp.Core.Models
@using BookLoggerApp.Core.Resources
@using BookLoggerApp.Core.ViewModels
@using Microsoft.Extensions.Localization
@implements IDisposable
@inject SettingsViewModel ViewModel
@inject AppStartupViewModel StartupViewModel
@inject BookLoggerApp.Core.Services.Abstractions.IBackButtonService BackButtonService
@inject BookLoggerApp.Core.Services.Abstractions.IOnboardingService OnboardingService
@inject BookLoggerApp.Core.Services.Abstractions.IAppRestartService AppRestartService
@inject BookLoggerApp.Core.Services.Abstractions.IEntitlementService EntitlementService
@inject BookLoggerApp.Core.Services.Abstractions.IPaywallCoordinator PaywallCoordinator
@inject BookLoggerApp.Core.Services.Abstractions.IBillingService BillingService
@inject BookLoggerApp.Core.Services.Abstractions.ILanguageService LanguageService
@inject IStringLocalizer<AppResources> L
@inject IJSRuntime JSRuntime

<PageTitle>@L["Settings_Title"] - BookHeart</PageTitle>


<AnalyticsScreenTracker Screen="@BookLoggerApp.Core.Services.Analytics.ScreenNames.Settings" />
<link rel="stylesheet" href="css/settings.css" />

<div class="settings-container">
    @if (ViewModel.IsBusy)
    {
        <div class="loading">@L["Settings_Loading"]</div>
    }
    else if (!string.IsNullOrEmpty(ViewModel.ErrorMessage))
    {
        <div class="alert alert-danger">@ViewModel.ErrorMessage</div>
    }
    else
    {
        <!-- Hero -->
        <section class="settings-hero">
            <div class="settings-hero-copy">
                <span class="settings-kicker">BookHeart</span>
                <h1>@L["Settings_Title"]</h1>
                <p class="settings-hero-subtitle">@L["Settings_Subtitle"]</p>
            </div>
            <div class="settings-hero-version">
                <span class="version-label">@L["Settings_Version"]</span>
                <strong>@ViewModel.AppVersion</strong>
            </div>
        </section>

        <!-- Plus & Premium -->
        <section class="settings-card">
            <div class="section-header">
                <h2>⭐ @L["Settings_PlusPremium_Title"]</h2>
                <p>@L["Settings_PlusPremium_Subtitle"]</p>
            </div>

            <div class="setting-row">
                <div class="setting-info">
                    <span class="setting-label">@L["Settings_PlusPremium_CurrentPlan"]</span>
                    <span class="setting-description">
                        @switch (EntitlementService.CurrentTier)
                        {
                            case SubscriptionTier.Free:
                                <span>@L["Settings_PlusPremium_Tier_Free"]</span>
                                break;
                            case SubscriptionTier.Plus:
                                <span>@L["Settings_PlusPremium_Tier_Plus"]@(EntitlementService.CurrentEntitlement?.ExpiresAt is { } plusExpiry ? $" — {L["Settings_PlusPremium_RenewsOn", plusExpiry.ToString("yyyy-MM-dd")]}" : string.Empty)</span>
                                break;
                            case SubscriptionTier.Premium:
                                <span>@L["Settings_PlusPremium_Tier_Premium"]@(EntitlementService.CurrentEntitlement?.BillingPeriod == BillingPeriod.Lifetime ? " " + L["Settings_PlusPremium_Lifetime"] : EntitlementService.CurrentEntitlement?.ExpiresAt is { } premExpiry ? $" — {L["Settings_PlusPremium_RenewsOn", premExpiry.ToString("yyyy-MM-dd")]}" : string.Empty)</span>
                                break;
                        }
                    </span>
                </div>
            </div>

            @if (EntitlementService.CurrentTier == SubscriptionTier.Free)
            {
                <div class="setting-row" style="flex-wrap: wrap; gap: 0.5rem;">
                    <button class="btn btn-primary" @onclick="OpenPaywallAsync">@L["Settings_PlusPremium_Upgrade"]</button>
                    <button class="btn btn-link" @onclick="RestorePurchasesAsync">@L["Settings_PlusPremium_Restore"]</button>
                </div>
            }
            else if (EntitlementService.CurrentEntitlement?.BillingPeriod != BillingPeriod.Lifetime)
            {
                <div class="settings-entitlement-actions">
                    <button class="btn btn-secondary" @onclick="OpenPaywallAsync">@L["Settings_PlusPremium_ChangePlan"]</button>
                    <button class="btn btn-primary" @onclick="OpenSubscriptionManagementAsync">@L["Settings_PlusPremium_Manage"]</button>
                </div>
                <div class="setting-row" style="flex-wrap: wrap; gap: 0.5rem;">
                    <button class="btn btn-link" @onclick="RestorePurchasesAsync">@L["Settings_PlusPremium_Restore"]</button>
                </div>
            }
            else
            {
                <div class="setting-row" style="flex-wrap: wrap; gap: 0.5rem;">
                    <button class="btn btn-secondary" @onclick="OpenPaywallAsync">@L["Settings_PlusPremium_SeePlans"]</button>
                    <button class="btn btn-link" @onclick="RestorePurchasesAsync">@L["Settings_PlusPremium_Restore"]</button>
                </div>
            }

            @if (EntitlementService.HasAccess(FeatureKey.FeatureSuggestionForm))
            {
                <FeatureSuggestionForm />
            }
        </section>

        <!-- Notifications -->
        <section class="settings-card">
            <div class="section-header">
                <h2>🔔 @L["Settings_Notifications_Title"]</h2>
                <p>@L["Settings_Notifications_Subtitle"]</p>
            </div>

            <div class="setting-row">
                <div class="setting-info">
                    <span class="setting-label">@L["Settings_Notifications_Enable"]</span>
                    <span class="setting-description">@L["Settings_Notifications_EnableDescription"]</span>
                </div>
                <label class="toggle-switch">
                    <input type="checkbox"
                           checked="@ViewModel.Settings.NotificationsEnabled"
                           @onchange="@(async (ChangeEventArgs e) => await ViewModel.ToggleNotificationsCommand.ExecuteAsync((bool)(e.Value ?? false)))" />
                    <span class="toggle-slider"></span>
                </label>
            </div>

            @if (ViewModel.Settings.NotificationsEnabled)
            {
                <div class="setting-row">
                    <div class="setting-info">
                        <span class="setting-label">@L["Settings_Notifications_DailyReminder"]</span>
                        <span class="setting-description">@L["Settings_Notifications_DailyReminderDescription"]</span>
                    </div>
                    <label class="toggle-switch">
                        <input type="checkbox"
                               checked="@ViewModel.Settings.ReadingRemindersEnabled"
                               @onchange="@(async (ChangeEventArgs e) => await ViewModel.ToggleReadingRemindersCommand.ExecuteAsync((bool)(e.Value ?? false)))" />
                        <span class="toggle-slider"></span>
                    </label>
                </div>

                @if (ViewModel.Settings.ReadingRemindersEnabled)
                {
                    <div class="setting-row time-picker-row">
                        <div class="setting-info">
                            <span class="setting-label">@L["Settings_Notifications_ReminderTime"]</span>
                            <span class="setting-description">@L["Settings_Notifications_ReminderTimeDescription"]</span>
                        </div>
                        <div class="time-picker">
                            <select class="time-select"
                                    value="@ViewModel.ReminderHour"
                                    @onchange="@(async (ChangeEventArgs e) => { ViewModel.ReminderHour = int.Parse(e.Value?.ToString() ?? "20"); await ViewModel.UpdateReminderTimeCommand.ExecuteAsync(null); })">
                                @for (int h = 0; h < 24; h++)
                                {
                                    var hour = h;
                                    <option value="@hour">@hour.ToString("D2")</option>
                                }
                            </select>
                            <span class="time-separator">:</span>
                            <select class="time-select"
                                    value="@ViewModel.ReminderMinute"
                                    @onchange="@(async (ChangeEventArgs e) => { ViewModel.ReminderMinute = int.Parse(e.Value?.ToString() ?? "0"); await ViewModel.UpdateReminderTimeCommand.ExecuteAsync(null); })">
                                @for (int m = 0; m < 60; m++)
                                {
                                    var minute = m;
                                    <option value="@minute">@minute.ToString("D2")</option>
                                }
                            </select>
                        </div>
                    </div>
                }
            }
        </section>

        <!-- Language -->
        <section class="settings-card">
            <div class="section-header">
                <h2>🌐 @L["Settings_Language_Title"]</h2>
                <p>@L["Settings_Language_Subtitle"]</p>
            </div>

            <div class="setting-row">
                <div class="setting-info">
                    <span class="setting-label">@L["Settings_Language_Label"]</span>
                    <span class="setting-description">@L["Settings_Language_Description"]</span>
                </div>
                <select class="time-select"
                        value="@ViewModel.SelectedLanguage"
                        @onchange="@(async (ChangeEventArgs e) => await HandleLanguageChangeAsync(e.Value?.ToString()))">
                    @foreach (var lang in ViewModel.SupportedLanguages)
                    {
                        <option value="@lang.Code">@lang.DisplayName</option>
                    }
                </select>
            </div>
        </section>

        <!-- Shelf Appearance (collapsible) -->
        <section class="settings-card">
            <button class="settings-collapse-toggle" @onclick="ToggleShelfAppearance">
                <span>🎨 @L["Settings_Shelf_Title"]</span>
                <span class="toggle-icon">@(_showShelfAppearance ? "▲" : "▼")</span>
            </button>

            @if (_showShelfAppearance)
            {
                <LockedFeatureButton Feature="FeatureKey.CustomShelfColors">
                    <div class="settings-collapse-content">
                        <ColorPresetPicker Label="@L["Settings_Shelf_LedgeColor"]"
                                           Description="@L["Settings_Shelf_LedgeDescription"]"
                                           SelectedColor="@ViewModel.ShelfLedgeColor"
                                           Presets="_shelfLedgeColorPresets"
                                           OnColorChanged="@(hex => ViewModel.UpdateShelfLedgeColorCommand.ExecuteAsync(hex))" />

                        <ColorPresetPicker Label="@L["Settings_Shelf_BarColor"]"
                                           Description="@L["Settings_Shelf_BarDescription"]"
                                           SelectedColor="@ViewModel.ShelfBaseColor"
                                           Presets="_shelfBaseColorPresets"
                                           OnColorChanged="@(hex => ViewModel.UpdateShelfBaseColorCommand.ExecuteAsync(hex))" />
                    </div>
                </LockedFeatureButton>
            }
        </section>

        <!-- Data & Backup (merged with Danger Zone) -->
        <section class="settings-card">
            <div class="section-header">
                <h2>💾 @L["Settings_Data_Title"]</h2>
                <p>@L["Settings_Data_Subtitle"]</p>
            </div>
            <div class="settings-action-grid data-backup-grid">
                <button class="btn btn-primary" @onclick="HandleBackupToCloudAsync">
                    @L["Settings_Data_Backup"]
                </button>
                <button class="btn btn-secondary" @onclick="HandleRestoreFromBackupAsync">
                    @L["Settings_Data_Restore"]
                </button>
            </div>

            <hr class="danger-divider" />

            <div class="danger-subblock">
                <h3>⚠️ @L["Settings_Danger_Title"]</h3>
                <p class="danger-description">
                    @L["Settings_Danger_Description"]
                </p>
                <button class="btn btn-danger" @onclick="ShowDeleteConfirmation">
                    @L["Settings_Danger_DeleteAll"]
                </button>
            </div>
        </section>

        <!-- Help & Community (merged Support me + Getting Started) -->
        <section class="settings-card">
            <div class="section-header">
                <h2>💛 @L["Settings_Help_Title"]</h2>
                <p>@L["Settings_Help_Subtitle"]</p>
            </div>
            <div class="settings-action-grid help-action-grid">
                <button class="btn btn-primary" @onclick="OpenGettingStarted">
                    @L["Settings_Help_GettingStarted"]
                </button>
                <button class="btn btn-secondary" @onclick="ReplayIntroFromSettingsAsync">
                    @L["Settings_Help_ReplayIntro"]
                </button>
                <button class="btn btn-secondary" @onclick="OpenChangelogAsync">
                    @L["Settings_Help_WhatsNew"]
                </button>
                <button id="buy-me-a-coffee-fallback"
                        class="btn buy-me-a-coffee-fallback"
                        type="button"
                        @onclick="OpenBuyMeACoffee">
                    @L["Settings_Help_BuyMeCoffee"]
                </button>
            </div>

            <div class="setting-row">
                <div class="setting-info">
                    <span class="setting-label">@L["Settings_Help_HideCta"]</span>
                    <span class="setting-description">@L["Settings_Help_HideCtaDescription"]</span>
                </div>
                <label class="toggle-switch">
                    <input type="checkbox"
                           checked="@ViewModel.Settings.HideGettingStartedCta"
                           @onchange="@(e => ViewModel.ToggleGettingStartedCtaCommand.ExecuteAsync((bool)e.Value!))" />
                    <span class="toggle-slider"></span>
                </label>
            </div>
        </section>

        <!-- Privacy (Firebase Analytics & Crashlytics opt-out) -->
        <section id="privacy" class="settings-card">
            <div class="section-header">
                <h2>🔒 @L["Settings_Privacy_Title"]</h2>
                <p>@L["Settings_Privacy_Subtitle"]</p>
            </div>

            <div class="setting-row">
                <div class="setting-info">
                    <span class="setting-label">@L["Settings_Privacy_UsageStats"]</span>
                    <span class="setting-description">
                        @L["Settings_Privacy_UsageStatsDescription"]
                    </span>
                </div>
                <label class="toggle-switch">
                    <input type="checkbox"
                           checked="@ViewModel.Settings.AnalyticsEnabled"
                           @onchange="@(e => ViewModel.ToggleAnalyticsCommand.ExecuteAsync((bool)e.Value!))" />
                    <span class="toggle-slider"></span>
                </label>
            </div>

            <div class="setting-row">
                <div class="setting-info">
                    <span class="setting-label">@L["Settings_Privacy_CrashReports"]</span>
                    <span class="setting-description">
                        @L["Settings_Privacy_CrashReportsDescription"]
                    </span>
                </div>
                <label class="toggle-switch">
                    <input type="checkbox"
                           checked="@ViewModel.Settings.CrashReportingEnabled"
                           @onchange="@(e => ViewModel.ToggleCrashReportingCommand.ExecuteAsync((bool)e.Value!))" />
                    <span class="toggle-slider"></span>
                </label>
            </div>

            <p class="privacy-note">
                @L["Settings_Privacy_DisableNote"]
            </p>
        </section>

        <!-- More Info (Diagnostics + Privacy Policy) -->
        <section class="settings-card">
            <button class="settings-collapse-toggle" @onclick="ToggleMoreInfo">
                <span>ⓘ @L["Settings_MoreInfo_Title"]</span>
                <span class="toggle-icon">@(_showMoreInfo ? "▲" : "▼")</span>
            </button>

            @if (_showMoreInfo)
            {
                <div class="settings-collapse-content more-info-content">
                    <button class="settings-collapse-toggle nested" @onclick="ToggleMigrationLog">
                        <span>@L["Settings_MoreInfo_Diagnostics"]</span>
                        <span class="toggle-icon">@(_showMigrationLog ? "▲" : "▼")</span>
                    </button>
                    @if (_showMigrationLog)
                    {
                        <div class="migration-log-container">
                            <textarea class="migration-log" readonly>@ViewModel.MigrationLog</textarea>
                            <p class="migration-hint">
                                @L["Settings_MoreInfo_DiagnosticsHint"]
                            </p>
                        </div>
                    }

                    <button class="settings-collapse-toggle nested" @onclick="TogglePrivacyPolicy">
                        <span>@L["Settings_PrivacyPolicy_Title"]</span>
                        <span class="toggle-icon">@(_showPrivacyPolicy ? "▲" : "▼")</span>
                    </button>
                    @if (_showPrivacyPolicy)
                    {
                        <div class="privacy-content">
                            <p class="privacy-updated">@L["Settings_PrivacyPolicy_LastUpdated"]</p>

                            <h3>@L["Settings_PrivacyPolicy_Overview_Title"]</h3>
                            <p>@L["Settings_PrivacyPolicy_Overview_Body"]</p>

                            <h3>@L["Settings_PrivacyPolicy_Storage_Title"]</h3>
                            <p>@L["Settings_PrivacyPolicy_Storage_Body"]</p>

                            <h3>@L["Settings_PrivacyPolicy_Camera_Title"]</h3>
                            <p>@L["Settings_PrivacyPolicy_Camera_Body"]</p>

                            <h3>@L["Settings_PrivacyPolicy_Network_Title"]</h3>
                            <p>@L["Settings_PrivacyPolicy_Network_Body"]</p>

                            <h3>@L["Settings_PrivacyPolicy_ThirdParty_Title"]</h3>
                            <p>@L["Settings_PrivacyPolicy_ThirdParty_Body"]</p>

                            <h3>@L["Settings_PrivacyPolicy_Deletion_Title"]</h3>
                            <p>@L["Settings_PrivacyPolicy_Deletion_Body"]</p>

                            <h3>@L["Settings_PrivacyPolicy_Children_Title"]</h3>
                            <p>@L["Settings_PrivacyPolicy_Children_Body"]</p>

                            <h3>@L["Settings_PrivacyPolicy_Changes_Title"]</h3>
                            <p>@L["Settings_PrivacyPolicy_Changes_Body"]</p>

                            <h3>@L["Settings_PrivacyPolicy_Contact_Title"]</h3>
                            <p>@L["Settings_PrivacyPolicy_Contact_Body"]</p>
                        </div>
                    }
                </div>
            }
        </section>
    }
</div>

<!-- Delete Confirmation Modal -->
@if (_showDeleteConfirmation)
{
    <div class="modal-overlay" @onclick="HideDeleteConfirmation">
        <div class="modal-content delete-modal" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>@L["Settings_Delete_Title"]</h3>
            </div>
            <div class="modal-body">
                <p class="warning-text">
                    @L["Settings_Delete_Warning"]
                </p>
                <ul class="delete-list">
                    <li>@L["Settings_Delete_Item_Books"]</li>
                    <li>@L["Settings_Delete_Item_Sessions"]</li>
                    <li>@L["Settings_Delete_Item_Goals"]</li>
                    <li>@L["Settings_Delete_Item_Plants"]</li>
                    <li>@L["Settings_Delete_Item_Progress"]</li>
                    <li>@L["Settings_Delete_Item_Coins"]</li>
                </ul>
                <p class="confirm-text">
                    @((MarkupString)L["Settings_Delete_TypeConfirm"].Value)
                </p>
                <input type="text"
                       class="confirm-input"
                       @bind="_deleteConfirmText"
                       @bind:event="oninput"
                       placeholder="@L["Settings_Delete_Placeholder"]" />
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="HideDeleteConfirmation">@L["Common_Cancel"]</button>
                <button class="btn btn-danger"
                        @onclick="ConfirmDeleteAllData"
                        disabled="@(!IsDeleteConfirmed)">
                    @L["Settings_Delete_Confirm"]
                </button>
            </div>
        </div>
    </div>
}

<!-- Success Modal -->
@if (_showSuccessModal)
{
    <div class="modal-overlay" @onclick="CloseSuccessAndNavigate">
        <div class="modal-content success-modal" @onclick:stopPropagation="true">
            <div class="modal-body">
                <div class="success-icon">&#10003;</div>
                <h3>@L["Settings_Delete_Success_Title"]</h3>
                <p>@L["Settings_Delete_Success_Body"]</p>
            </div>
            <div class="modal-footer">
                <button class="btn btn-primary" @onclick="CloseSuccessAndNavigate">@L["Common_Ok"]</button>
            </div>
        </div>
    </div>
}

<!-- Restart Notice (after successful backup restore) -->
@if (_showRestartNotice)
{
    <div class="modal-overlay">
        <div class="modal-content success-modal" @onclick:stopPropagation="true">
            <div class="modal-body">
                <div class="success-icon">&#10003;</div>
                <h3>@L["Settings_Restart_BackupTitle"]</h3>
                <p>@L["Settings_Restart_BackupBody"]</p>
            </div>
        </div>
    </div>
}

<!-- Restart Notice (after language change) -->
@if (_showLanguageRestartNotice)
{
    <div class="modal-overlay">
        <div class="modal-content success-modal" @onclick:stopPropagation="true">
            <div class="modal-body">
                <div class="success-icon">🌐</div>
                <h3>@L["Settings_Restart_LanguageTitle"]</h3>
                <p>@L["Settings_Restart_LanguageBody"]</p>
            </div>
        </div>
    </div>
}

@code {
    private bool _showDeleteConfirmation = false;
    private bool _showSuccessModal = false;
    private bool _showRestartNotice = false;
    private bool _showLanguageRestartNotice = false;
    private bool _showPrivacyPolicy = false;
    private bool _showMigrationLog = false;
    private bool _showShelfAppearance = false;
    private bool _showMoreInfo = false;
    private string _deleteConfirmText = string.Empty;

    private async Task HandleLanguageChangeAsync(string? code)
    {
        if (string.IsNullOrWhiteSpace(code))
        {
            return;
        }

        await ViewModel.ChangeLanguageCommand.ExecuteAsync(code);

        if (string.IsNullOrEmpty(ViewModel.ErrorMessage) && ViewModel.LanguageChangedPendingRestart)
        {
            _showLanguageRestartNotice = true;
            StateHasChanged();
            await Task.Delay(1500);
            AppRestartService.RestartApp();
        }
    }

    private bool IsDeleteConfirmed => _deleteConfirmText.Equals("DELETE", StringComparison.Ordinal);

    private static readonly (string Name, string Hex)[] _shelfLedgeColorPresets =
    [
        ("Classic Wood", "#8B7355"),
        ("Dark Oak", "#5A3E2B"),
        ("Cherry", "#8B4513"),
        ("Mahogany", "#6B3A3A"),
        ("Walnut", "#4A3728"),
        ("Ebony", "#3D3126"),
        ("White Oak", "#B8A088"),
        ("Birch", "#C8AA82"),
    ];

    private static readonly (string Name, string Hex)[] _shelfBaseColorPresets =
    [
        ("Warm Gold", "#D4A574"),
        ("Soft Tan", "#C9A97F"),
        ("Classic Wood", "#8B7355"),
        ("Dark Oak", "#5A3E2B"),
        ("Cherry", "#8B4513"),
        ("Mahogany", "#6B3A3A"),
        ("Walnut", "#4A3728"),
        ("Birch", "#C8AA82"),
    ];

    private void TogglePrivacyPolicy() => _showPrivacyPolicy = !_showPrivacyPolicy;

    private void ToggleMigrationLog() => _showMigrationLog = !_showMigrationLog;

    private Task OpenPaywallAsync() => PaywallCoordinator.ShowAsync(trigger: null);

    private async Task OpenSubscriptionManagementAsync()
    {
        await BillingService.OpenSubscriptionManagementAsync(EntitlementService.CurrentEntitlement?.ProductId);
    }

    private async Task RestorePurchasesAsync()
    {
        try
        {
            if (!BillingService.IsConnected)
            {
                await BillingService.ConnectAsync();
            }

            if (BillingService.IsConnected)
            {
                var active = await BillingService.QueryActivePurchasesAsync();
                foreach (var purchase in active)
                {
                    await EntitlementService.ApplyPurchaseAsync(purchase, EntitlementChangeReason.Restore);
                }

                if (active.Count == 0
                    && EntitlementService.CurrentTier != SubscriptionTier.Free
                    && EntitlementService.CurrentEntitlement?.BillingPeriod != BillingPeriod.Lifetime)
                {
                    await EntitlementService.ApplyLapseAsync("expired");
                }
            }

            await EntitlementService.RefreshAsync();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"RestorePurchasesAsync failed: {ex}");
        }
    }

    private void ToggleShelfAppearance() => _showShelfAppearance = !_showShelfAppearance;

    private void ToggleMoreInfo() => _showMoreInfo = !_showMoreInfo;

    private Func<Task<bool>>? _navBackHandler;
    private Func<Task<bool>>? _modalBackHandler;

    protected override async Task OnInitializedAsync()
    {
        // Register navigation back handler (Settings -> Bookshelf)
        _navBackHandler = async () =>
        {
            Navigation.NavigateTo("/");
            return true;
        };
        BackButtonService.Register(_navBackHandler);

        // Re-render when a purchase, lapse, promo, or debug-tier-switch changes the
        // active entitlement so "Current plan" updates immediately without requiring
        // a page reload or back-and-forth navigation.
        EntitlementService.EntitlementChanged += OnEntitlementChanged;

        await ViewModel.LoadCommand.ExecuteAsync(null);
    }

    private void OnEntitlementChanged(object? sender, BookLoggerApp.Core.Entitlements.EntitlementChangedEventArgs e)
    {
        _ = InvokeAsync(StateHasChanged);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await JSRuntime.InvokeVoidAsync(
            "settingsSupport.loadBuyMeACoffeeButton",
            "buy-me-a-coffee-widget",
            "buy-me-a-coffee-fallback");
    }

    private void OpenGettingStarted()
    {
        Navigation.NavigateTo("/getting-started");
    }

    private async Task ReplayIntroFromSettingsAsync()
    {
        await OnboardingService.ResetIntroAsync();
        Navigation.NavigateTo("/");
    }

    private async Task OpenChangelogAsync()
    {
        await StartupViewModel.OpenChangelogAsync();
    }

    private async Task HandleBackupToCloudAsync()
    {
        await ViewModel.BackupToCloudCommand.ExecuteAsync(null);

        if (string.IsNullOrWhiteSpace(ViewModel.ErrorMessage))
        {
            await OnboardingService.TrackEventAsync(OnboardingEvent.BackupCreated);
        }
    }

    private async Task HandleRestoreFromBackupAsync()
    {
        await ViewModel.RestoreFromBackupCommand.ExecuteAsync(null);

        // SQLite keeps stale file handles on the old database even after
        // ClearAllPools + WAL/SHM cleanup, so the only reliable way to guarantee
        // the restored data is usable is a full process restart. We check
        // BackupRestoreSucceeded instead of ErrorMessage so that a post-restore
        // read failure (from a pre-restore DbContext still in memory) can't
        // mask a successful restore.
        if (ViewModel.BackupRestoreSucceeded)
        {
            // Re-seed the Preferences language mirror from the restored AppSettings so
            // the first render after restart already uses the restored language.
            try { await LanguageService.SyncFromSettingsAsync(); } catch { }

            _showRestartNotice = true;
            StateHasChanged();
            await Task.Delay(1500);
            AppRestartService.RestartApp();
        }
    }

    private void ShowDeleteConfirmation()
    {
        _deleteConfirmText = string.Empty;

         // Register modal back handler
        _modalBackHandler = async () =>
        {
            HideDeleteConfirmation();
            return true;
        };
        BackButtonService.Register(_modalBackHandler);

        _showDeleteConfirmation = true;
    }

    private void HideDeleteConfirmation()
    {
        if (_modalBackHandler != null)
        {
            BackButtonService.Unregister(_modalBackHandler);
            _modalBackHandler = null;
        }
        _showDeleteConfirmation = false;
        _deleteConfirmText = string.Empty;
    }

    private async Task ConfirmDeleteAllData()
    {
        if (!IsDeleteConfirmed) return;

        _showDeleteConfirmation = false;
        if (_modalBackHandler != null)
        {
            BackButtonService.Unregister(_modalBackHandler);
            _modalBackHandler = null;
        }

        await ViewModel.DeleteAllDataCommand.ExecuteAsync(null);

        if (string.IsNullOrEmpty(ViewModel.ErrorMessage))
        {
            _showSuccessModal = true;
            // Register success modal handler (just close/navigate)
             _modalBackHandler = async () =>
            {
                CloseSuccessAndNavigate();
                return true;
            };
            BackButtonService.Register(_modalBackHandler);
        }
    }

    private void CloseSuccessAndNavigate()
    {
        if (_modalBackHandler != null)
        {
            BackButtonService.Unregister(_modalBackHandler);
            _modalBackHandler = null;
        }
        _showSuccessModal = false;
        // Force page refresh to reflect reset state
        Navigation.NavigateTo("/", forceLoad: true);
    }

    private async Task OpenBuyMeACoffee()
    {
        await Microsoft.Maui.ApplicationModel.Browser.Default.OpenAsync(
            new Uri("https://buymeacoffee.com/tristanatzk"),
            Microsoft.Maui.ApplicationModel.BrowserLaunchMode.SystemPreferred);
    }

    [Inject]
    private NavigationManager Navigation { get; set; } = default!;

    public void Dispose()
    {
        EntitlementService.EntitlementChanged -= OnEntitlementChanged;

        if (_navBackHandler != null)
        {
            BackButtonService.Unregister(_navBackHandler);
            _navBackHandler = null;
        }
         if (_modalBackHandler != null)
        {
            BackButtonService.Unregister(_modalBackHandler);
            _modalBackHandler = null;
        }
    }
}
