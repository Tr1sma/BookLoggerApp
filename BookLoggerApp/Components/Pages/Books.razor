@page "/books"
@using BookLoggerApp.Core.Resources
@using Microsoft.Extensions.Localization
@inherits BookLoggerApp.Components.ObservableComponentBase
@inject BookLoggerApp.Core.ViewModels.BookListViewModel Vm
@inject IStringLocalizer<AppResources> L

<PageTitle>@L["PageTitle_Books"] - BookHeart</PageTitle>

<AnalyticsScreenTracker Screen="@BookLoggerApp.Core.Services.Analytics.ScreenNames.BookList" />

<h1>@L["Books_Title"]</h1>

@if (Vm.IsBusy)
{
    <p>@L["Common_Loading"]</p>
}
else
{
    <div>
        <input placeholder="@L["Books_Title_Placeholder"]" @bind="Vm.NewTitle" />
        <input placeholder="@L["Books_Author_Placeholder"]" @bind="Vm.NewAuthor" />
        <button @onclick="Vm.AddAsync" disabled="@(!Vm.AddAsyncCommand.CanExecute(null))">@L["Books_Add"]</button>
    </div>

    <ul>
        @foreach (var b in Vm.Items)
        {
            <li>
                <a href="@($"/books/{b.Id}")">@b.Title</a> — @b.Author (@b.Status)
            </li>
        }
    </ul>
}

@code {
    protected override async Task OnInitializedAsync()
    {
        Observe(Vm);
        await Vm.LoadAsync();
    }
}
