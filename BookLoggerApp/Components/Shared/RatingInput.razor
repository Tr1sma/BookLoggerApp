@using BookLoggerApp.Core.Resources
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<AppResources> L

<div class="rating-input">
    <div class="rating-header">
        <span class="rating-emoji" aria-hidden="true">@Emoji</span>
        <span class="rating-label">@Label</span>
    </div>
    @* Radiogroup so keyboard users can focus/activate stars and screen readers announce the rating *@
    <div class="rating-stars" role="radiogroup" aria-label="@Label">
        @for (int i = 1; i <= 5; i++)
        {
            int starValue = i;
            <span class="star @GetStarClass(starValue)"
                  role="radio"
                  aria-checked="@(((Rating ?? 0) == starValue) ? "true" : "false")"
                  aria-label="@L["RatingInput_RateValue", starValue].Value"
                  tabindex="@(ReadOnly ? "-1" : "0")"
                  @onclick="() => OnStarClick(starValue)"
                  @onkeydown="@(e => OnStarKeydown(e, starValue))"
                  @onmouseover="() => OnStarHover(starValue)"
                  @onmouseout="OnStarHoverEnd"
                  style="@(ReadOnly ? "cursor: default;" : "cursor: pointer;")">
                ★
            </span>
        }
        @if (Rating.HasValue && !ReadOnly)
        {
            <button class="clear-rating" @onclick="ClearRating" aria-label="@L["RatingInput_Clear"].Value">✕</button>
        }
    </div>
    @if (Rating.HasValue)
    {
        <div class="rating-value-display">@Rating.Value / 5</div>
    }
</div>

@code {
    [Parameter] public string Emoji { get; set; } = string.Empty;
    [Parameter] public string Label { get; set; } = string.Empty;
    [Parameter] public int? Rating { get; set; }
    [Parameter] public EventCallback<int?> RatingChanged { get; set; }
    [Parameter] public bool ReadOnly { get; set; } = false;

    private int? hoverRating = null;

    private string GetStarClass(int starValue)
    {
        int displayRating = hoverRating ?? Rating ?? 0;

        if (starValue <= displayRating)
            return hoverRating.HasValue ? "filled hover" : "filled";

        return "empty";
    }

    private async Task OnStarClick(int starValue)
    {
        if (ReadOnly) return;

        // Clicking the current rating clears it
        if (Rating == starValue)
        {
            await ClearRating();
        }
        else
        {
            Rating = starValue;
            await RatingChanged.InvokeAsync(Rating);
        }
    }

    private async Task OnStarKeydown(KeyboardEventArgs e, int starValue)
    {
        if (ReadOnly) return;

        if (e.Key == "Enter" || e.Key == " ")
        {
            await OnStarClick(starValue);
        }
    }

    private void OnStarHover(int starValue)
    {
        if (!ReadOnly)
        {
            hoverRating = starValue;
        }
    }

    private void OnStarHoverEnd()
    {
        hoverRating = null;
    }

    private async Task ClearRating()
    {
        if (ReadOnly) return;

        Rating = null;
        await RatingChanged.InvokeAsync(null);
    }
}
