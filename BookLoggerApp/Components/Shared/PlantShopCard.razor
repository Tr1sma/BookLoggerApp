@using BookLoggerApp.Core.Models
@using BookLoggerApp.Core.Resources
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<AppResources> L

<div class="plant-shop-card @(IsSelected ? "selected" : "") @(IsLockedByLevel ? "locked" : "") @(IsLegendary ? "legendary" : "")" @onclick="OnSelect" style="display: flex; flex-direction: column;">
    <!-- Plant Image -->
    <div class="plant-card-image">
        <img src="@Species.ImagePath" alt="@Species.Name" />
    </div>

    <!-- Plant Info -->
    <div class="plant-card-body">
        @if (IsLegendary)
        {
            <div class="legendary-badge">✨ @L["ShopCard_Legendary"]</div>
        }
        <h3 class="plant-card-title">@Species.Name</h3>
        <p class="plant-card-description">@Species.Description</p>

        <!-- Stats -->
        <div class="plant-card-stats">
            <div class="stat-mini">
                <span class="stat-icon">📊</span>
                <span>@L["Stats_LevelAbbrev"] @Species.MaxLevel</span>
            </div>
            <div class="stat-mini">
                <span class="stat-icon">💧</span>
                <span>@Species.WaterIntervalDays @L["ShopCard_DayUnit"]</span>
            </div>
            <div class="stat-mini">
                <span class="stat-icon">⚡</span>
                <span>@Species.GrowthRate.ToString("0.0")x</span>
            </div>
        </div>

        <!-- Price -->
        <div class="plant-card-footer">
            <span class="plant-cost @(UserCoins >= CurrentPrice ? "affordable" : "expensive")">
                🪙 @CurrentPrice
            </span>
            @if (IsLockedByLevel)
            {
                <span class="buy-label locked">@L["ShopCard_UnlocksAt", Species.UnlockLevel]</span>
            }

        </div>
    </div>

    <!-- Locked Overlay for entire card -->
    @if (IsLockedByLevel)
    {
        <div class="locked-overlay-full">
            <div class="lock-content">
                <span class="lock-icon-large">🔒</span>
                <span class="lock-text">@L["Shop_RequiresLevel", Species.UnlockLevel]</span>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public PlantSpecies Species { get; set; } = null!;
    [Parameter] public int UserCoins { get; set; }
    [Parameter] public int UserLevel { get; set; }
    [Parameter] public int CurrentPrice { get; set; }
    [Parameter] public bool IsSelected { get; set; }
    [Parameter] public EventCallback OnSelect { get; set; }

    private bool IsLockedByLevel => UserLevel < Species.UnlockLevel;

    private bool IsLegendary => !string.IsNullOrEmpty(Species.SpecialAbilityKey);
}
