@using BookLoggerApp.Core.Enums
@using BookLoggerApp.Core.Helpers
@using BookLoggerApp.Core.Models
@using BookLoggerApp.Core.Resources
@using BookLoggerApp.Core.Services.Abstractions
@using BookLoggerApp.Components.Shared
@using Microsoft.Extensions.Localization
@implements IDisposable
@inject IProgressService ProgressService
@inject IBookService BookService
@inject ITimerStateService TimerStateService
@inject IAppSettingsProvider AppSettings
@inject IStringLocalizer<AppResources> L

@if (Book != null && IsVisible)
{
    <div class="quick-timer-overlay" @onclick="HandleOverlayClick">
        <div class="quick-timer-widget" @onclick:stopPropagation="true">
            <div class="quick-timer-header">
                <div class="quick-timer-book-info">
                    <h3>@Book.Title</h3>
                    <p>@Book.Author</p>
                </div>
                <button class="btn-close" @onclick="HandleClose">✕</button>
            </div>

            <div class="quick-timer-display">
                <div class="timer-value">@FormatTime(ElapsedTime)</div>
                <div class="timer-status">@(IsRunning ? L["QuickTimer_Status_Reading"].Value : (ElapsedTime.TotalSeconds > 0 ? L["QuickTimer_Status_Paused"].Value : L["QuickTimer_Status_Ready"].Value))</div>
            </div>

            <div class="quick-timer-pages">
                <label>@L["Reading_PagesRead"]</label>
                <div class="pages-input-group">
                    <button class="btn-adjust" @onclick="DecrementPages" disabled="@(PagesRead <= 0)">-</button>
                    <input type="number"
                           class="pages-input-compact"
                           @bind="PagesRead"
                           min="0"
                           placeholder="0" />
                    <button class="btn-adjust" @onclick="IncrementPages">+</button>
                </div>
            </div>

            <div class="quick-timer-controls">
                @if (!IsRunning && ElapsedTime.TotalSeconds == 0)
                {
                    <button class="btn btn-primary btn-large" @onclick="HandleStart">
                        ▶ @L["QuickTimer_StartReading"]
                    </button>
                }
                else if (IsRunning)
                {
                    <button class="btn btn-secondary btn-large" @onclick="HandlePause">
                        ⏸ @L["Reading_Pause"]
                    </button>
                }
                else
                {
                    <button class="btn btn-primary" @onclick="HandleResume">
                        ▶ @L["Reading_Resume"]
                    </button>
                    <button class="btn btn-success" @onclick="HandleSave">
                        ✓ @L["QuickTimer_SaveSession"]
                    </button>
                }
            </div>

            @if (ElapsedTime.TotalSeconds > 0)
            {
                <div class="quick-timer-info">
                    <div class="info-item">
                        <span class="info-label">@L["QuickTimer_Time"]:</span>
                        <span class="info-value">@FormatTime(ElapsedTime)</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">@L["QuickTimer_Pages"]:</span>
                        <span class="info-value">@PagesRead</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">XP:</span>
                        <span class="info-value">@CalculateXP() XP</span>
                    </div>
                </div>
            }

            @if (_moodTrackingEnabled && !IsRunning && ElapsedTime.TotalSeconds > 0)
            {
                <SessionMoodPicker @bind-Value="_selectedMoods" />
            }
        </div>
    </div>
}

@code {
    [Parameter] public Book? Book { get; set; }
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnSessionSaved { get; set; }

    private DateTime? StartTime { get; set; }
    private TimeSpan ElapsedTime { get; set; } = TimeSpan.Zero;
    private TimeSpan PausedTime { get; set; } = TimeSpan.Zero;
    private bool IsRunning { get; set; }
    private int PagesRead { get; set; }
    private System.Threading.Timer? _timer;
    private Guid? _currentBookId;

    private IReadOnlyList<SessionMood> _selectedMoods = Array.Empty<SessionMood>();
    private bool _moodTrackingEnabled = true;

    protected override void OnInitialized()
    {
        TimerStateService.AppResumed += OnAppResumed;
    }

    protected override async Task OnInitializedAsync()
    {
        _moodTrackingEnabled = (await AppSettings.GetSettingsAsync()).MoodTrackingEnabled;
    }

    protected override void OnParametersSet()
    {
        // guard: parent re-renders must not reset elapsed time
        if (Book != null && Book.Id != _currentBookId)
        {
            _currentBookId = Book.Id;
            ResetTimer();
        }
    }

    private void OnAppResumed()
    {
        if (IsRunning && StartTime.HasValue)
        {
            ElapsedTime = DateTime.UtcNow - StartTime.Value;
            StartTimer();
            InvokeAsync(StateHasChanged);
        }
    }

    private void HandleStart()
    {
        StartTime = DateTime.UtcNow;
        IsRunning = true;
        PausedTime = TimeSpan.Zero;
        ElapsedTime = TimeSpan.Zero;
        StartTimer();
    }

    private void HandlePause()
    {
        IsRunning = false;
        PausedTime = ElapsedTime;
        StopTimer();
    }

    private void HandleResume()
    {
        StartTime = DateTime.UtcNow - PausedTime;
        IsRunning = true;
        StartTimer();
    }

    private async Task HandleSave()
    {
        if (Book == null || ElapsedTime.TotalSeconds == 0) return;

        StopTimer();

        try
        {

            await ProgressService.AddSessionAsync(new ReadingSession
            {
                BookId = Book.Id,
                StartedAt = StartTime ?? DateTime.UtcNow,
                EndedAt = DateTime.UtcNow,
                Minutes = (int)Math.Ceiling(ElapsedTime.TotalMinutes),
                PagesRead = PagesRead > 0 ? PagesRead : null,
                XpEarned = CalculateXP(),
                Moods = SessionMoodHelper.Clamp(_selectedMoods)
                    .Select(m => new ReadingSessionMood { Mood = m }).ToList()
            });

            if (PagesRead > 0)
            {
                var currentPage = Book.CurrentPage + PagesRead;
                await BookService.UpdateProgressAsync(Book.Id, currentPage);
            }


            await OnSessionSaved.InvokeAsync();
            await HandleClose();
            ResetTimer();
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Failed to save session: {ex.Message}");
        }
    }

    private async Task HandleClose()
    {
        StopTimer();
        IsRunning = false;
        _currentBookId = null;
        await OnClose.InvokeAsync();
    }

    private async Task HandleOverlayClick() => await HandleClose();

    private void IncrementPages()
    {
        PagesRead++;
    }

    private void DecrementPages()
    {
        if (PagesRead > 0)
        {
            PagesRead--;
        }
    }

    private void ResetTimer()
    {
        ElapsedTime = TimeSpan.Zero;
        PausedTime = TimeSpan.Zero;
        StartTime = null;
        IsRunning = false;
        PagesRead = 0;
        _selectedMoods = Array.Empty<SessionMood>();
    }

    private int CalculateXP()
    {
        int minutes = (int)Math.Ceiling(ElapsedTime.TotalMinutes);
        int baseXp = (minutes * 5) + (PagesRead * 20);
        if (minutes >= 60) baseXp += 50;
        // streak bonus and plant boost applied by ProgressService on save
        return baseXp;
    }

    private string FormatTime(TimeSpan time)
    {
        if (time.TotalHours >= 1)
        {
            return $"{(int)time.TotalHours:D2}:{time.Minutes:D2}:{time.Seconds:D2}";
        }
        return $"{time.Minutes:D2}:{time.Seconds:D2}";
    }

    private void StartTimer()
    {
        _timer?.Dispose();
        _timer = new System.Threading.Timer(_ =>
        {
            if (IsRunning && StartTime.HasValue)
            {
                ElapsedTime = DateTime.UtcNow - StartTime.Value;
                InvokeAsync(StateHasChanged);
            }
        }, null, TimeSpan.Zero, TimeSpan.FromSeconds(1));
    }

    private void StopTimer()
    {
        _timer?.Dispose();
        _timer = null;
    }

    public void Dispose()
    {
        TimerStateService.AppResumed -= OnAppResumed;
        StopTimer();
    }
}
