@using BookLoggerApp.Core.Enums
@using BookLoggerApp.Core.Models
@using BookLoggerApp.Core.Resources
@using BookLoggerApp.Core.Services.Abstractions
@using BookLoggerApp.Components.Shared
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.Extensions.Localization
@implements IDisposable
@inject IProgressService ProgressService
@inject IBookService BookService
@inject ITimerStateService TimerStateService
@inject IReadingTimerNotificationService TimerNotification
@inject IShareCardService ShareCardService
@inject IImageService CoverImageService
@inject IShareService ShareService
@inject IAppSettingsProvider AppSettings
@inject Microsoft.AspNetCore.Components.NavigationManager Navigation
@inject IReviewPromptService ReviewPromptService
@inject IStringLocalizer<AppResources> L

@if (Book != null)
{
    <div class="reading-timer-inline">
        <!-- Timer Header -->
        <div class="timer-inline-header">
            <h3>📖 @L["TimerInline_Title"]</h3>
            @if (!IsRunning && ElapsedTime.TotalSeconds == 0)
            {
                <span class="timer-status-badge ready">@L["TimerInline_ReadyToRead"]</span>
            }
            else if (IsRunning)
            {
                <span class="timer-status-badge active">● @L["TimerInline_Active"]</span>
            }
            else
            {
                <span class="timer-status-badge paused">⏸ @L["QuickTimer_Status_Paused"]</span>
            }
        </div>

        <!-- Main Timer Display -->
        <div class="timer-inline-main">
            <div class="timer-display-column">
                <div class="timer-display-large">
                    <div class="timer-icon">⏱️</div>
                    @if (_isEditingTime)
                    {
                        <input type="text"
                               class="timer-value-input"
                               @bind="_timeInputText"
                               @bind:event="oninput"
                               placeholder="00:00"
                               @onkeydown="HandleTimeInputKeyDown"
                               @onblur="HandleTimeBlur"
                               @onclick:stopPropagation="true"
                               @ref="_timeInputRef" />
                    }
                    else if (CanEditTime)
                    {
                        <button type="button" class="timer-value-large timer-value-button" @onclick="BeginTimeEdit">
                            @FormatTime(ElapsedTime)
                        </button>
                    }
                    else
                    {
                        <div class="timer-value-large">@FormatTime(ElapsedTime)</div>
                    }
                </div>
                @if (!string.IsNullOrEmpty(_timeInputError))
                {
                    <p class="timer-time-error">@_timeInputError</p>
                }
                @if (CanEditTime && !_isEditingTime)
                {
                    <p class="timer-edit-hint">@L["TimerInline_EditTimeHint"]</p>
                }
            </div>

            <!-- Controls -->
            <div class="timer-controls-inline">
                @if (!IsRunning && ElapsedTime.TotalSeconds == 0)
                {
                    <button class="btn btn-primary btn-large" @onclick="HandleStart">
                        ▶ @L["QuickTimer_StartReading"]
                    </button>
                }
                else if (IsRunning)
                {
                    <button class="btn btn-secondary btn-large" @onclick="HandlePause">
                        ⏸ @L["Reading_Pause"]
                    </button>
                }
                else
                {
                    <button class="btn btn-primary" @onclick="HandleResume">
                        ▶ @L["Reading_Resume"]
                    </button>
                    <button class="btn btn-success" @onclick="HandleSave">
                        ✓ @L["QuickTimer_SaveSession"]
                    </button>
                    <button class="btn btn-danger" @onclick="HandleCancel">
                        ✕ @L["Common_Cancel"]
                    </button>
                }
            </div>
        </div>

        <!-- Session Details - Only show after timer is paused -->
        @if (!IsRunning && ElapsedTime.TotalSeconds > 0)
        {
            <div class="timer-inline-details">
                <div class="timer-detail-row">
                    <div class="timer-detail-item">
                        <label>@L["Reading_CurrentPage"]</label>
                        <div class="pages-input-group-inline">
                            <button class="btn-adjust" @onclick="DecrementCurrentPage" disabled="@(CurrentPageInput <= Book.CurrentPage)">-</button>
                            <input type="number"
                                   class="pages-input-inline"
                                   @bind="CurrentPageInput"
                                   @bind:event="oninput"
                                   min="@Book.CurrentPage"
                                   max="@(Book.PageCount ?? 9999)"
                                   placeholder="@Book.CurrentPage.ToString()" />
                            <button class="btn-adjust" @onclick="IncrementCurrentPage">+</button>
                        </div>
                        <small class="input-hint">@L["TimerInline_WasOnPage", Book.CurrentPage]</small>
                    </div>

                    <div class="timer-detail-item">
                        <label>@L["Reading_PagesRead"]</label>
                        <div class="pages-display">
                            @L["TimerInline_PagesValue", CalculatePagesRead()]
                        </div>
                    </div>

                    <div class="timer-detail-item">
                        <label>@L["TimerInline_XpToEarn"]</label>
                        <div class="xp-display-inline">
                            <span class="xp-value">@CalculateXP()</span>
                            <span class="xp-label">XP</span>
                        </div>
                    </div>

                    <div class="timer-detail-item">
                        <label>@L["TimerInline_Minutes"]</label>
                        <div class="minutes-display">
                            @L["TimerInline_MinutesValue", (int)Math.Ceiling(ElapsedTime.TotalMinutes)]
                        </div>
                    </div>
                </div>

                @if (_moodTrackingEnabled)
                {
                    <SessionMoodPicker @bind-Value="_selectedMoods" />
                }
            </div>
        }

        @if (Book.PageCount.HasValue && !IsRunning && ElapsedTime.TotalSeconds > 0 && CalculatePagesRead() > 0)
        {
            <div class="timer-progress-info">
                <p class="progress-text">
                    @L["TimerInline_Progress", Book.CurrentPage, CurrentPageInput, Book.PageCount, CalculateNewProgressPercentage()]
                </p>
            </div>
        }
    </div>
}

<!-- Celebration Overlays -->
@if (ShowSessionCelebration && SessionProgressionResult != null)
{
    <SessionCompleteCelebration
        Result="@SessionProgressionResult"
        StreakRescuedByGuardian="@StreakRescuedByGuardian"
        StoryHeartCoinBonus="@StoryHeartCoinBonus"
        StoryHeartFirstOfDayBonusXp="@StoryHeartFirstOfDayBonusXp"
        OnClose="@HandleSessionCelebrationClose" />
}

@if (ShowStreakCelebration && SessionProgressionResult != null)
{
    <StreakCelebration
        StreakDays="@SessionProgressionResult.StreakDays"
        BonusXp="@SessionProgressionResult.StreakBonusXp"
        OnClose="@HandleStreakCelebrationClose" />
}

@if (ShowLevelUpCelebration && LevelUpResult != null)
{
    <LevelUpCelebration
        Result="@LevelUpResult"
        OnClose="@HandleLevelUpCelebrationClose" />
}

@if (ShowBookCompletionCelebration && BookCompletedDuringSession && Book != null)
{
    <BookCompletionCelebration
        IsVisible="true"
        Book="@Book"
        TotalXpEarned="@(SessionProgressionResult?.XpEarned ?? 0)"
        ShowShareButton="true"
        IsGeneratingCard="@_isGeneratingBookCard"
        OnClose="@HandleBookCompletionCelebrationClose"
        OnShareBook="@HandleShareBookFromTimer" />
}

@if (ShowReviewPrompt)
{
    <ReviewPromptModal
        IsVisible="@ShowReviewPrompt"
        OnClose="@HandleReviewPromptClose"
        OnNeverAskAgain="@HandleNeverAskAgainAsync" />
}

@code {
    [Parameter] public Book? Book { get; set; }
    [Parameter] public EventCallback OnSessionSaved { get; set; }

    private DateTime? StartTime { get; set; }
    private TimeSpan ElapsedTime { get; set; } = TimeSpan.Zero;
    private TimeSpan PausedTime { get; set; } = TimeSpan.Zero;
    private bool IsRunning { get; set; }
    private int CurrentPageInput { get; set; }
    private int PagesRead => CalculatePagesRead();
    private System.Threading.Timer? _timer;

    // Session tracking for EndSessionAsync
    private Guid? CurrentSessionId { get; set; }

    // Celebration state
    private bool ShowSessionCelebration { get; set; }
    private ProgressionResult? SessionProgressionResult { get; set; }
    private bool ShowStreakCelebration { get; set; }
    private bool StreakCelebrationPending { get; set; }
    private bool ShowLevelUpCelebration { get; set; }
    private LevelUpResult? LevelUpResult { get; set; }
    private bool GoalCompletedDuringSession { get; set; }
    private bool BookCompletedDuringSession { get; set; }
    private bool StreakRescuedByGuardian { get; set; }
    private int StoryHeartCoinBonus { get; set; }
    private int StoryHeartFirstOfDayBonusXp { get; set; }
    private bool ShowBookCompletionCelebration { get; set; }
    private bool _isGeneratingBookCard;
    private bool ShowReviewPrompt { get; set; }
    private bool ReviewPromptPending { get; set; }

    // Mood/Trigger tracking
    private IReadOnlyList<SessionMood> _selectedMoods = Array.Empty<SessionMood>();
    private bool _moodTrackingEnabled = true;

    // State restoration tracking
    private bool _stateRestoreAttempted;

    // Manual time entry
    private bool _isEditingTime;
    private string _timeInputText = "";
    private string? _timeInputError;
    private ElementReference _timeInputRef;
    private bool _focusTimeInputOnNextRender;

    private bool CanEditTime => !IsRunning;

    protected override void OnInitialized()
    {
        TimerStateService.AppResumed += OnAppResumed;
        TimerStateService.ExternalCommandReceived += OnExternalCommand;
    }

    protected override async Task OnInitializedAsync()
    {
        _moodTrackingEnabled = (await AppSettings.GetSettingsAsync()).MoodTrackingEnabled;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_focusTimeInputOnNextRender)
        {
            _focusTimeInputOnNextRender = false;
            await _timeInputRef.FocusAsync();
        }
    }

    protected override void OnParametersSet()
    {
        // Try to restore persisted timer state once when the Book parameter is first available
        if (Book != null && !_stateRestoreAttempted)
        {
            _stateRestoreAttempted = true;
            TryRestoreTimerState();
        }

        // Initialize CurrentPageInput when book loads or after reset
        // Also update if book has progressed beyond current input (e.g., after saving a session)
        if (Book != null)
        {
            // Always update if we're not in an active session
            if (!IsRunning && ElapsedTime.TotalSeconds == 0)
            {
                CurrentPageInput = Book.CurrentPage;
            }
            // Or if the book's current page has changed (e.g., after saving)
            else if (CurrentPageInput < Book.CurrentPage)
            {
                CurrentPageInput = Book.CurrentPage;
            }
        }
    }

    private void TryRestoreTimerState()
    {
        if (Book == null) return;

        var state = TimerStateService.LoadState();
        if (state == null || state.BookId != Book.Id)
        {
            // No saved state or it belongs to a different book — nothing to restore
            if (state != null) TimerStateService.ClearState();
            return;
        }

        // Discard sessions older than 12 hours (user likely forgot to stop the timer)
        var elapsed = DateTime.UtcNow - state.StartTimeUtc;
        if (elapsed.TotalHours > 12)
        {
            TimerStateService.ClearState();
            return;
        }

        CurrentSessionId = state.SessionId;

        if (state.IsRunning)
        {
            // Timer was actively running — resume it
            StartTime = state.StartTimeUtc;
            ElapsedTime = DateTime.UtcNow - state.StartTimeUtc;
            PausedTime = TimeSpan.Zero;
            IsRunning = true;
            StartTimer();
        }
        else
        {
            // Timer was paused — restore paused state
            StartTime = DateTime.UtcNow - state.PausedElapsed;
            PausedTime = state.PausedElapsed;
            ElapsedTime = state.PausedElapsed;
            IsRunning = false;
        }

        UpdateTimerNotification();
    }

    private void OnAppResumed()
    {
        if (IsRunning && StartTime.HasValue)
        {
            // Recalculate elapsed time from the original start time —
            // DateTime.UtcNow - StartTime correctly accounts for background time
            ElapsedTime = DateTime.UtcNow - StartTime.Value;
            StartTimer();
            InvokeAsync(StateHasChanged);
        }
    }

    private void PersistTimerState()
    {
        if (Book == null || !CurrentSessionId.HasValue || !StartTime.HasValue) return;

        TimerStateService.SaveState(new TimerStateData
        {
            SessionId = CurrentSessionId.Value,
            BookId = Book.Id,
            StartTimeTicks = StartTime.Value.Ticks,
            IsRunning = IsRunning,
            PausedElapsedTicks = IsRunning ? 0 : PausedTime.Ticks
        });
    }

    private void UpdateTimerNotification()
    {
        if (Book == null || !CurrentSessionId.HasValue || !StartTime.HasValue) return;

        var data = new ReadingTimerNotificationData(
            SessionId: CurrentSessionId.Value,
            BookId: Book.Id,
            BookTitle: Book.Title,
            StartTimeUtc: StartTime.Value,
            Elapsed: ElapsedTime,
            IsRunning: IsRunning);

        if (IsRunning)
            TimerNotification.ShowRunning(data);
        else
            TimerNotification.ShowPaused(data);
    }

    /// <summary>
    /// Applies a timer command relayed from the lock-screen notification.
    /// Stop only pauses — finalizing needs the end page entered in this component.
    /// </summary>
    private void OnExternalCommand(ExternalTimerCommand command)
    {
        InvokeAsync(() =>
        {
            if (Book == null || !CurrentSessionId.HasValue) return;

            switch (command)
            {
                case ExternalTimerCommand.Pause:
                    if (IsRunning) HandlePause();
                    break;
                case ExternalTimerCommand.Resume:
                    if (!IsRunning && ElapsedTime > TimeSpan.Zero) HandleResume();
                    break;
                case ExternalTimerCommand.Stop:
                    if (IsRunning) HandlePause();
                    break;
            }

            StateHasChanged();
        });
    }

    private async Task HandleStart()
    {
        if (Book == null) return;

        try
        {
            // Create new session via ProgressService
            var session = await ProgressService.StartSessionAsync(Book.Id);
            CurrentSessionId = session.Id;

            StartTime = DateTime.UtcNow;
            IsRunning = true;
            PausedTime = TimeSpan.Zero;
            ElapsedTime = TimeSpan.Zero;
            StartTimer();
            PersistTimerState();
            UpdateTimerNotification();
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Failed to start session: {ex.Message}");
        }
    }

    private void HandlePause()
    {
        IsRunning = false;
        PausedTime = ElapsedTime;
        StopTimer();
        PersistTimerState();
        UpdateTimerNotification();
    }

    private void BeginTimeEdit()
    {
        if (!CanEditTime || _isEditingTime)
        {
            return;
        }

        _timeInputError = null;
        _timeInputText = ElapsedTime.TotalSeconds > 0 ? FormatTime(ElapsedTime) : "";
        _isEditingTime = true;
        _focusTimeInputOnNextRender = true;
    }

    private void CancelTimeEdit()
    {
        _isEditingTime = false;
        _timeInputText = "";
        _timeInputError = null;
    }

    private async Task HandleTimeBlur()
    {
        await CommitTimeEdit();
    }

    private async Task HandleTimeInputKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape")
        {
            CancelTimeEdit();
            return;
        }

        if (e.Key == "Enter")
        {
            await CommitTimeEdit();
        }
    }

    private async Task CommitTimeEdit()
    {
        if (!_isEditingTime)
        {
            return;
        }

        if (!TryParseDuration(_timeInputText.Trim(), out TimeSpan duration))
        {
            _timeInputError = L["TimerInline_InvalidDuration"].Value;
            _isEditingTime = false;
            _timeInputText = "";
            return;
        }

        _isEditingTime = false;
        _timeInputText = "";
        _timeInputError = null;
        await ApplyPausedElapsedAsync(duration);
    }

    private async Task ApplyPausedElapsedAsync(TimeSpan elapsed)
    {
        if (Book == null || elapsed.TotalSeconds <= 0 || elapsed.TotalHours > 24)
        {
            return;
        }

        try
        {
            if (!CurrentSessionId.HasValue)
            {
                ReadingSession session = await ProgressService.StartSessionAsync(Book.Id);
                CurrentSessionId = session.Id;
            }

            ElapsedTime = elapsed;
            PausedTime = elapsed;
            IsRunning = false;
            StartTime = DateTime.UtcNow - elapsed;
            StopTimer();
            if (CurrentPageInput == 0)
            {
                CurrentPageInput = Book.CurrentPage;
            }

            PersistTimerState();
            UpdateTimerNotification();
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Failed to apply manual time: {ex.Message}");
        }
    }

    private static bool TryParseDuration(string input, out TimeSpan duration)
    {
        duration = TimeSpan.Zero;
        if (string.IsNullOrWhiteSpace(input))
        {
            return false;
        }

        input = input.Trim();
        if (!input.Contains(':'))
        {
            if (!int.TryParse(input, out int minutesOnly) || minutesOnly <= 0)
            {
                return false;
            }

            duration = TimeSpan.FromMinutes(minutesOnly);
            return duration.TotalSeconds > 0 && duration.TotalHours <= 24;
        }

        string[] parts = input.Split(':');
        if (parts.Length == 2)
        {
            if (!int.TryParse(parts[0], out int mm) || !int.TryParse(parts[1], out int ss))
            {
                return false;
            }

            if (mm < 0 || ss < 0 || ss >= 60)
            {
                return false;
            }

            duration = new TimeSpan(0, mm, ss);
        }
        else if (parts.Length == 3)
        {
            if (!int.TryParse(parts[0], out int hh) || !int.TryParse(parts[1], out int mm) || !int.TryParse(parts[2], out int ss))
            {
                return false;
            }

            if (hh < 0 || mm < 0 || ss < 0 || mm >= 60 || ss >= 60)
            {
                return false;
            }

            duration = new TimeSpan(hh, mm, ss);
        }
        else
        {
            return false;
        }

        return duration.TotalSeconds > 0 && duration.TotalHours <= 24;
    }

    private void HandleResume()
    {
        StartTime = DateTime.UtcNow - PausedTime;
        IsRunning = true;
        StartTimer();
        PersistTimerState();
        UpdateTimerNotification();
    }

    private async Task HandleSave()
    {
        if (Book == null || ElapsedTime.TotalSeconds == 0 || !CurrentSessionId.HasValue) return;

        StopTimer();
        TimerStateService.ClearState();
        TimerNotification.Hide();

        try
        {
            var pagesRead = CalculatePagesRead();
            var bookCompletedDuringSession =
                Book.Status != ReadingStatus.Completed &&
                Book.PageCount.HasValue &&
                CurrentPageInput >= Book.PageCount.Value;

            // End session using ProgressService which handles XP, streak, plant boost, level-ups
            int minutes = (int)Math.Ceiling(ElapsedTime.TotalMinutes);
            var result = await ProgressService.EndSessionAsync(CurrentSessionId.Value, pagesRead, minutes, _selectedMoods);

            // Update book progress if pages were read
            if (pagesRead > 0)
            {
                await BookService.UpdateProgressAsync(Book.Id, CurrentPageInput);
            }

            // Store progression result for celebration
            SessionProgressionResult = result.ProgressionResult;
            StreakRescuedByGuardian = result.StreakRescuedByGuardian;
            StoryHeartCoinBonus = result.StoryHeartCoinBonus;
            StoryHeartFirstOfDayBonusXp = result.StoryHeartFirstOfDayBonusXp;
            var streakCelebrationPending = ShouldShowStreakCelebration(SessionProgressionResult);

            // Reset timer state
            ResetTimer();
            GoalCompletedDuringSession = result.GoalCompleted;
            BookCompletedDuringSession = bookCompletedDuringSession;
            StreakCelebrationPending = streakCelebrationPending;
            ReviewPromptPending = false;

            // Notify parent to refresh
            await OnSessionSaved.InvokeAsync();

            // Show the appropriate celebration
            if (bookCompletedDuringSession)
            {
                // Skip session XP modal — go directly to book completion celebration
                ShowBookCompletionCelebration = true;
            }
            else
            {
                ShowSessionCelebration = true;
            }

            // Check if there was a level-up to show afterwards
            if (result.ProgressionResult.LevelUp != null)
            {
                LevelUpResult = result.ProgressionResult.LevelUp;
            }
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Failed to save session: {ex.Message}");
        }
    }

    private async Task HandleCancel()
    {
        StopTimer();
        TimerStateService.ClearState();
        TimerNotification.Hide();
        var sessionId = CurrentSessionId;
        ResetTimer();

        if (!sessionId.HasValue)
        {
            return;
        }

        try
        {
            await ProgressService.DeleteSessionAsync(sessionId.Value);
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Failed to delete canceled session: {ex.Message}");
        }
    }

    private void IncrementCurrentPage()
    {
        if (Book != null && Book.PageCount.HasValue && CurrentPageInput < Book.PageCount.Value)
        {
            CurrentPageInput++;
        }
        else if (Book != null && !Book.PageCount.HasValue)
        {
            CurrentPageInput++;
        }
    }

    private void DecrementCurrentPage()
    {
        if (Book != null && CurrentPageInput > Book.CurrentPage)
        {
            CurrentPageInput--;
        }
    }

    private int CalculatePagesRead()
    {
        if (Book == null) return 0;
        return Math.Max(0, CurrentPageInput - Book.CurrentPage);
    }

    private void ResetTimer()
    {
        ElapsedTime = TimeSpan.Zero;
        PausedTime = TimeSpan.Zero;
        StartTime = null;
        IsRunning = false;
        CurrentPageInput = 0; // Reset to 0, will be re-initialized in OnParametersSet
        CurrentSessionId = null;
        _selectedMoods = Array.Empty<SessionMood>();
        GoalCompletedDuringSession = false;
        BookCompletedDuringSession = false;
        StreakCelebrationPending = false;
        ShowStreakCelebration = false;
        ShowBookCompletionCelebration = false;
        ReviewPromptPending = false;
    }

    private async Task HandleSessionCelebrationClose()
    {
        var shouldShowReviewPrompt = ReviewPromptPending || ShouldShowReviewPrompt();
        ShowSessionCelebration = false;

        if (StreakCelebrationPending)
        {
            StreakCelebrationPending = false;
            ShowStreakCelebration = true;
            ReviewPromptPending = shouldShowReviewPrompt;
        }
        else if (LevelUpResult != null)
        {
            ShowLevelUpCelebration = true;
            ReviewPromptPending = shouldShowReviewPrompt;
        }
        else if (BookCompletedDuringSession)
        {
            ShowBookCompletionCelebration = true;
            ReviewPromptPending = shouldShowReviewPrompt;
        }
        else
        {
            ReviewPromptPending = false;
            GoalCompletedDuringSession = false;
            await TryShowReviewPromptOrNavigateAsync(shouldShowReviewPrompt);
        }
    }

    private async Task HandleStreakCelebrationClose()
    {
        var shouldShowReviewPrompt = ReviewPromptPending || ShouldShowReviewPrompt();
        ShowStreakCelebration = false;
        ReviewPromptPending = false;

        if (!BookCompletedDuringSession && LevelUpResult != null)
        {
            ShowLevelUpCelebration = true;
        }
        else
        {
            BookCompletedDuringSession = false;
            GoalCompletedDuringSession = false;
            await TryShowReviewPromptOrNavigateAsync(shouldShowReviewPrompt);
        }
    }

    private async Task HandleLevelUpCelebrationClose()
    {
        var shouldShowReviewPrompt = ReviewPromptPending || ShouldShowReviewPrompt();
        ShowLevelUpCelebration = false;
        LevelUpResult = null;
        ReviewPromptPending = false;

        if (BookCompletedDuringSession)
        {
            ShowBookCompletionCelebration = true;
        }
        else
        {
            GoalCompletedDuringSession = false;
            await TryShowReviewPromptOrNavigateAsync(shouldShowReviewPrompt);
        }
    }

    private async Task HandleBookCompletionCelebrationClose()
    {
        var shouldShowReviewPrompt = ReviewPromptPending || ShouldShowReviewPrompt();
        ShowBookCompletionCelebration = false;

        if (StreakCelebrationPending)
        {
            BookCompletedDuringSession = false;
            StreakCelebrationPending = false;
            ShowStreakCelebration = true;
            ReviewPromptPending = shouldShowReviewPrompt;
        }
        else
        {
            BookCompletedDuringSession = false;
            GoalCompletedDuringSession = false;
            ReviewPromptPending = false;
            await TryShowReviewPromptOrNavigateAsync(shouldShowReviewPrompt);
        }
    }

    private async Task HandleShareBookFromTimer()
    {
        if (Book == null) return;

        _isGeneratingBookCard = true;
        StateHasChanged();

        try
        {
            int totalMinutes = await ProgressService.GetTotalMinutesAsync(Book.Id);

            byte[]? coverBytes = null;
            var coverResult = await CoverImageService.GetResizedCoverImageAsync(Book.Id, 600, 900);
            if (coverResult.HasValue)
            {
                coverBytes = coverResult.Value.Bytes;
            }

            var data = new BookShareData
            {
                Title = Book.Title,
                Author = Book.Author,
                PageCount = Book.PageCount,
                TotalMinutesRead = totalMinutes,
                AverageRating = Book.AverageRating,
                CoverImageBytes = coverBytes,
                CategoryRatings = new Dictionary<RatingCategory, int?>
                {
                    { RatingCategory.Characters, Book.CharactersRating },
                    { RatingCategory.Plot, Book.PlotRating },
                    { RatingCategory.WritingStyle, Book.WritingStyleRating },
                    { RatingCategory.SpiceLevel, Book.SpiceLevelRating },
                    { RatingCategory.Pacing, Book.PacingRating },
                    { RatingCategory.WorldBuilding, Book.WorldBuildingRating },
                    { RatingCategory.Spannung, Book.SpannungRating },
                    { RatingCategory.Humor, Book.HumorRating },
                    { RatingCategory.Informationsgehalt, Book.InformationsgehaltRating },
                    { RatingCategory.EmotionaleTiefe, Book.EmotionaleTiefeRating },
                    { RatingCategory.Atmosphaere, Book.AtmosphaereRating }
                }
            };

            byte[] cardBytes = await ShareCardService.GenerateBookCardAsync(data);

            var fileName = $"bookheart_recommendation_{DateTime.Now:yyyyMMdd_HHmmss}.png";
            var filePath = Path.Combine(FileSystem.CacheDirectory, fileName);
            await File.WriteAllBytesAsync(filePath, cardBytes);
            await ShareService.ShareFileAsync(L["Reading_ShareFileName"], filePath, "image/png");
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Failed to generate share card: {ex.Message}");
        }
        finally
        {
            _isGeneratingBookCard = false;
            StateHasChanged();
        }
    }

    private Task HandleReviewPromptClose()
    {
        ShowReviewPrompt = false;
        ReviewPromptPending = false;
        Navigation.NavigateTo("/bookshelf");
        return Task.CompletedTask;
    }

    private async Task HandleNeverAskAgainAsync()
    {
        ShowReviewPrompt = false;
        ReviewPromptPending = false;
        await ReviewPromptService.DisablePromptAsync();
        Navigation.NavigateTo("/bookshelf");
    }

    private bool ShouldShowReviewPrompt()
    {
        return GoalCompletedDuringSession || BookCompletedDuringSession || LevelUpResult != null;
    }

    private static bool ShouldShowStreakCelebration(ProgressionResult? result)
    {
        return result?.StreakDays >= 2 && result.StreakBonusXp > 0;
    }

    private async Task TryShowReviewPromptOrNavigateAsync(bool shouldShowReviewPrompt)
    {
        if (shouldShowReviewPrompt && await ReviewPromptService.TryStartPromptAsync())
        {
            ShowReviewPrompt = true;
            return;
        }

        Navigation.NavigateTo("/bookshelf");
    }

    private int CalculateXP()
    {
        // Use correct XP formula: 5 XP per minute, 20 XP per page
        int minutes = (int)Math.Ceiling(ElapsedTime.TotalMinutes);
        int pagesRead = CalculatePagesRead();
        int baseXp = (minutes * 5) + (pagesRead * 20);

        // Add long session bonus (50 XP for 60+ minutes)
        if (minutes >= 60)
        {
            baseXp += 50;
        }

        // Note: Streak bonus and plant boost are applied on save by ProgressService
        return baseXp;
    }

    private int CalculateNewProgressPercentage()
    {
        if (Book?.PageCount == null || Book.PageCount == 0) return 0;
        return (CurrentPageInput * 100) / Book.PageCount.Value;
    }

    private string FormatTime(TimeSpan time)
    {
        if (time.TotalHours >= 1)
        {
            return $"{(int)time.TotalHours:D2}:{time.Minutes:D2}:{time.Seconds:D2}";
        }
        return $"{time.Minutes:D2}:{time.Seconds:D2}";
    }

    private void StartTimer()
    {
        _timer?.Dispose();
        _timer = new System.Threading.Timer(_ =>
        {
            if (IsRunning && StartTime.HasValue)
            {
                ElapsedTime = DateTime.UtcNow - StartTime.Value;
                InvokeAsync(StateHasChanged);
            }
        }, null, TimeSpan.Zero, TimeSpan.FromSeconds(1));
    }

    private void StopTimer()
    {
        _timer?.Dispose();
        _timer = null;
    }

    public void Dispose()
    {
        TimerStateService.AppResumed -= OnAppResumed;
        TimerStateService.ExternalCommandReceived -= OnExternalCommand;
        StopTimer();
    }
}
