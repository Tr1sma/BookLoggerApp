@using BookLoggerApp.Core.Resources
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<AppResources> L

@if (IsVisible)
{
    <div class="review-prompt-overlay">
        <div class="review-prompt-modal" role="dialog" aria-modal="true" aria-labelledby="reviewPromptTitle">
            @if (!_showStorePrompt)
            {
                <h3 id="reviewPromptTitle" class="review-prompt-title">@L["Review_LikePrompt"]</h3>
                <p class="review-prompt-text">
                    @L["Review_LikeBody"]
                </p>
                <div class="review-prompt-actions">
                    <button type="button" class="btn review-prompt-never-btn" @onclick="NeverAskAgainAsync">@L["Review_NeverAsk"]</button>
                    <button type="button" class="btn btn-secondary" @onclick="CloseAsync">@L["Common_No"]</button>
                    <button type="button" class="btn btn-primary" @onclick="ShowStorePrompt">@L["Common_Yes"]</button>
                </div>
            }
            else
            {
                <h3 id="reviewPromptTitle" class="review-prompt-title">@L["Review_StorePrompt"]</h3>
                <p class="review-prompt-text">
                    @L["Review_StoreBody"]
                </p>
                <div class="review-prompt-actions">
                    <button type="button" class="btn review-prompt-never-btn" @onclick="NeverAskAgainAsync">@L["Review_NeverAsk"]</button>
                    <button type="button" class="btn btn-secondary" @onclick="CloseAsync">@L["Common_No"]</button>
                    <button type="button" class="btn btn-primary" @onclick="OpenStoreAndCloseAsync">@L["Common_Yes"]</button>
                </div>
            }
        </div>
    </div>
}

@code {
    private const string PlayStoreUrl = "https://play.google.com/store/apps/details?id=com.bookheart.app";
    private bool _showStorePrompt;

    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnNeverAskAgain { get; set; }

    protected override void OnParametersSet()
    {
        if (!IsVisible)
        {
            _showStorePrompt = false;
        }
    }

    private void ShowStorePrompt()
    {
        _showStorePrompt = true;
    }

    private async Task OpenStoreAndCloseAsync()
    {
        try
        {
            await Microsoft.Maui.ApplicationModel.Browser.Default.OpenAsync(
                new Uri(PlayStoreUrl),
                Microsoft.Maui.ApplicationModel.BrowserLaunchMode.SystemPreferred);
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Failed to open Play Store page: {ex.Message}");
        }

        await CloseAsync();
    }

    private async Task NeverAskAgainAsync()
    {
        _showStorePrompt = false;
        await OnNeverAskAgain.InvokeAsync();
    }

    private async Task CloseAsync()
    {
        _showStorePrompt = false;
        await OnClose.InvokeAsync();
    }
}