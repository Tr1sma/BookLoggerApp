@using BookLoggerApp.Core.Models
@using BookLoggerApp.Core.Enums
@using BookLoggerApp.Core.Helpers
@using BookLoggerApp.Core.Resources
@using BookLoggerApp.Infrastructure.Services.Helpers
@using Microsoft.Extensions.Localization
@inject BookLoggerApp.Core.Services.Abstractions.IDecorationService DecorationService
@inject IStringLocalizer<AppResources> L

<div class="plant-detail-card">
    <div class="plant-detail-visual">
        <img src="@(Plant.Species?.ImagePath ?? "/images/unknown_plant.png")"
             alt="@Plant.LocalizedDisplayName(L)"
             class="plant-detail-image" />
        <div class="plant-detail-status status-@Plant.Status.ToString().ToLowerInvariant()">
            @GetStatusIcon()
        </div>
    </div>

    <div class="plant-detail-content">
        <div class="plant-detail-name-row">
            @if (_isEditingName)
            {
                <input @ref="_nameInput"
                       type="text"
                       class="plant-detail-name-input"
                       value="@_editedName"
                       @oninput="HandleNameInput"
                       @onkeydown="HandleNameInputKeyDown"
                       @onblur="HandleNameBlur"
                       maxlength="100"
                       disabled="@IsRenaming"
                       aria-label="@L["PlantDetail_PlantName"]" />
            }
            else
            {
                <h3 class="plant-detail-name">@Plant.LocalizedDisplayName(L)</h3>
                <button type="button"
                        class="plant-detail-edit-btn"
                        @onclick="BeginRename"
                        disabled="@IsRenaming"
                        aria-label="@L["PlantDetail_Rename"]"
                        title="@L["PlantDetail_Rename"]">
                    ✏️
                </button>
            }
        </div>

        @if (!string.IsNullOrWhiteSpace(_renameError))
        {
            <p class="plant-detail-name-error">@_renameError</p>
        }

        <p class="plant-detail-species">@(Plant.Species?.LocalizedName(L) ?? L["PlantCard_UnknownPlant"].Value)</p>

        <div class="plant-detail-stats">
            <div class="plant-detail-stat">
                <span class="plant-detail-label">@L["Shop_LevelPrefix"]</span>
                <span class="plant-detail-value">@(Plant.CurrentLevel) / @GetMaxLevel()</span>
            </div>
            <div class="plant-detail-stat">
                <span class="plant-detail-label">@L["PlantDetail_NextWater"]</span>
                <span class="plant-detail-value">@GetNextWaterText()</span>
            </div>
        </div>

        @if (Plant.Status == PlantStatus.Dead)
        {
            <p class="plant-detail-note">@L["PlantDetail_DriedOut"]</p>
        }

        <button class="btn btn-water-now"
                @onclick="() => OnWater.InvokeAsync()"
                disabled="@IsWaterButtonDisabled">
            @if (IsWatering)
            {
                <span>💧 @L["PlantWidget_Watering"]</span>
            }
            else if (Plant.Status == PlantStatus.Healthy)
            {
                <span>💧 @L["PlantDetail_AlreadyWatered"]</span>
            }
            else if (Plant.Status == PlantStatus.Dead)
            {
                <span>💧 @L["PlantDetail_CannotWater"]</span>
            }
            else
            {
                <span>💧 @L["PlantWidget_WaterPlant"]</span>
            }
        </button>
    </div>
</div>

@code {
    [Parameter] public UserPlant Plant { get; set; } = null!;
    [Parameter] public EventCallback OnWater { get; set; }
    [Parameter] public bool IsWatering { get; set; }
    [Parameter] public EventCallback<string> OnRename { get; set; }
    [Parameter] public bool IsRenaming { get; set; }

    private ElementReference _nameInput;
    private bool _focusNameInput;
    private bool _isEditingName;
    private string _editedName = string.Empty;
    private string? _renameError;

    // Mirrors PlantService.GetGlobalGrowthMultiplierAsync: Herz der Geschichten halves the
    // effective water interval. Without this the "Next Water" countdown would disagree with
    // the plant's actual Thirsty/Wilting transitions.
    private double _growthMultiplier = 1.0;

    private bool IsWaterButtonDisabled => IsWatering || Plant.Status is PlantStatus.Healthy or PlantStatus.Dead;

    private int GetMaxLevel() => Plant.Species?.MaxLevel ?? 1;

    protected override async Task OnParametersSetAsync()
    {
        if (!_isEditingName)
        {
            _editedName = Plant.Name;
        }

        bool hasStoryHeart = await DecorationService.UserOwnsAbilityAsync(SpecialAbilityKeys.StoryHeart);
        _growthMultiplier = hasStoryHeart
            ? (double)SpecialAbilityResolver.StoryHeartPlantGrowthMultiplier
            : 1.0;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_focusNameInput)
        {
            _focusNameInput = false;
            await _nameInput.FocusAsync();
        }
    }

    private string GetStatusIcon() => Plant.Status switch
    {
        PlantStatus.Healthy => "😊",
        PlantStatus.Thirsty => "😰",
        PlantStatus.Wilting => "😵",
        PlantStatus.Dead => "💀",
        _ => "🌱"
    };

    private string GetNextWaterText()
    {
        var waterIntervalDays = Plant.Species?.WaterIntervalDays ?? 0;
        if (waterIntervalDays <= 0)
        {
            return L["PlantDetail_NextWater_Unknown"];
        }

        if (Plant.Status == PlantStatus.Dead)
        {
            return L["PlantDetail_NextWater_Missed"];
        }

        var nextWaterDue = PlantGrowthCalculator.GetNextWaterDueAt(Plant.LastWatered, waterIntervalDays, _growthMultiplier);
        var timeRemaining = nextWaterDue - DateTime.UtcNow;

        if (timeRemaining <= TimeSpan.Zero)
        {
            return L["PlantDetail_NextWater_Now"];
        }

        if (timeRemaining.TotalHours < 24)
        {
            return L["PlantDetail_NextWater_Hours", Math.Max(1, (int)Math.Ceiling(timeRemaining.TotalHours))];
        }

        return L["PlantDetail_NextWater_Days", Math.Max(1, (int)Math.Ceiling(timeRemaining.TotalDays))];
    }

    private void BeginRename()
    {
        _editedName = Plant.Name;
        _renameError = null;
        _isEditingName = true;
        _focusNameInput = true;
    }

    private void HandleNameInput(ChangeEventArgs args)
    {
        _editedName = args.Value?.ToString() ?? string.Empty;
        _renameError = null;
    }

    private async Task HandleNameBlur(FocusEventArgs _)
    {
        if (!_isEditingName || IsRenaming)
        {
            return;
        }

        await CommitRenameAsync();
    }

    private async Task HandleNameInputKeyDown(KeyboardEventArgs args)
    {
        if (args.Key == "Enter")
        {
            await CommitRenameAsync();
        }
        else if (args.Key == "Escape")
        {
            CancelRename();
        }
    }

    private async Task CommitRenameAsync()
    {
        if (!_isEditingName || IsRenaming)
        {
            return;
        }

        var trimmedName = _editedName.Trim();
        if (string.IsNullOrWhiteSpace(trimmedName))
        {
            _renameError = L["PlantDetail_Error_NameEmpty"];
            _focusNameInput = true;
            return;
        }

        if (trimmedName.Length > 100)
        {
            _renameError = L["PlantDetail_Error_NameTooLong"];
            _focusNameInput = true;
            return;
        }

        if (string.Equals(trimmedName, Plant.Name, StringComparison.Ordinal))
        {
            _renameError = null;
            _editedName = Plant.Name;
            _isEditingName = false;
            return;
        }

        try
        {
            _renameError = null;
            await OnRename.InvokeAsync(trimmedName);
            _editedName = trimmedName;
            _isEditingName = false;
        }
        catch (Exception ex)
        {
            _renameError = string.IsNullOrWhiteSpace(ex.Message)
                ? L["PlantDetail_Error_RenameFailed"]
                : ex.Message;
            _focusNameInput = true;
        }
    }

    private void CancelRename()
    {
        _renameError = null;
        _editedName = Plant.Name;
        _isEditingName = false;
    }
}
