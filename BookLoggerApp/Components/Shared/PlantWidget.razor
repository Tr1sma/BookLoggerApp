@using BookLoggerApp.Core.Models
@using BookLoggerApp.Core.Enums
@using BookLoggerApp.Core.Helpers
@using BookLoggerApp.Core.Resources
@using BookLoggerApp.Infrastructure.Services.Helpers
@using Microsoft.Extensions.Localization
@inject BookLoggerApp.Core.Services.Abstractions.IDecorationService DecorationService
@inject IStringLocalizer<AppResources> L

<div class="plant-widget @GetStatusClass()">
    <!-- Plant Visual -->
    <div class="plant-visual">
        <img src="@GetPlantImage()" alt="@Plant.LocalizedDisplayName(L)" class="plant-image-large" />
        <div class="plant-status-indicator">@GetStatusEmoji()</div>
    </div>

    <!-- Plant Info -->
    <div class="plant-info">
        <h3 class="plant-name">@Plant.LocalizedDisplayName(L)</h3>
        <p class="plant-species">@(Plant.Species?.LocalizedName(L) ?? L["PlantWidget_Unknown"].Value)</p>

        <!-- Level Badge -->
        <div class="plant-level">
            <span class="level-badge">@L["PlantWidget_Level", Plant.CurrentLevel, Plant.Species?.MaxLevel ?? 0]</span>
        </div>

        <!-- Reading Days Progress -->
        <div class="plant-progress">
            <div class="progress-bar">
                <div class="progress-fill" style="width: @GetProgressPercentage()%"></div>
            </div>
            <p class="progress-text">
                @if (Plant.Species == null || Plant.CurrentLevel >= Plant.Species.MaxLevel)
                {
                    <span>📖 @L["PlantWidget_ReadingDays_Max", Plant.ReadingDaysCount]</span>
                }
                else
                {
                    <span>📖 @L["PlantWidget_ReadingDays", Plant.ReadingDaysCount, GetDaysToNextLevel(), Plant.CurrentLevel + 1]</span>
                }
            </p>
        </div>

        <!-- Watering Status -->
        <div class="plant-watering">
            <p class="watering-status">@GetWateringStatus()</p>
            @if (Plant.Status != PlantStatus.Dead)
            {
                <button class="btn btn-water"
                        @onclick="() => OnWater.InvokeAsync()"
                        disabled="@(Plant.Status == PlantStatus.Healthy || IsWatering)">
                    @if (IsWatering)
                    {
                        <span>💧 @L["PlantWidget_Watering"]</span>
                    }
                    else
                    {
                        <span>💧 @L["PlantWidget_WaterPlant"]</span>
                    }
                </button>
            }
            else
            {
                <p class="plant-dead-message">😢 @L["PlantWidget_DeadMessage"]</p>
                @if (OnDelete.HasDelegate)
                {
                    <button class="btn btn-danger" @onclick="() => OnDelete.InvokeAsync()">
                        🗑️ @L["PlantWidget_DeleteDead"]
                    </button>
                }
            }
        </div>

        <!-- Days Until Water Needed -->
        @if (Plant.Status == PlantStatus.Healthy)
        {
            <p class="water-timer">
                @L["PlantWidget_NextWaterIn", GetDaysUntilWater()]
            </p>
        }
    </div>
</div>

@code {
    [Parameter] public UserPlant Plant { get; set; } = null!;
    [Parameter] public EventCallback OnWater { get; set; }
    [Parameter] public EventCallback OnDelete { get; set; }
    [Parameter] public bool IsWatering { get; set; }

    // Mirrors PlantService.GetGlobalGrowthMultiplierAsync: Herz der Geschichten halves the
    // reading-days needed per level. The widget's display helpers must use the same multiplier
    // as the authoritative level formula, otherwise "days to next level" is ~2× the actual value.
    private double _growthMultiplier = 1.0;

    protected override async Task OnParametersSetAsync()
    {
        bool hasStoryHeart = await DecorationService.UserOwnsAbilityAsync(SpecialAbilityKeys.StoryHeart);
        _growthMultiplier = hasStoryHeart
            ? (double)SpecialAbilityResolver.StoryHeartPlantGrowthMultiplier
            : 1.0;
    }

    private string GetPlantImage()
    {
        // In the future, could be level-dependent (different sprites for different levels)
        return Plant.Species?.ImagePath ?? "images/plants/placeholder.svg";
    }

    private string GetStatusClass()
    {
        return $"status-{Plant.Status.ToString().ToLower()}";
    }

    private string GetStatusEmoji()
    {
        return Plant.Status switch
        {
            PlantStatus.Healthy => "😊",
            PlantStatus.Thirsty => "😰",
            PlantStatus.Wilting => "😵",
            PlantStatus.Dead => "💀",
            _ => ""
        };
    }

    private string GetWateringStatus()
    {
        var daysSince = (DateTime.UtcNow - Plant.LastWatered).TotalDays;
        return Plant.Status switch
        {
            PlantStatus.Healthy => L["PlantWidget_Watered_Healthy", (int)daysSince],
            PlantStatus.Thirsty => L["PlantWidget_Watered_Thirsty"],
            PlantStatus.Wilting => L["PlantWidget_Watered_Wilting"],
            PlantStatus.Dead => L["PlantWidget_Watered_Dead"],
            _ => string.Empty
        };
    }

    private int GetProgressPercentage()
    {
        if (Plant.Species == null) return 0;
        if (Plant.CurrentLevel >= Plant.Species.MaxLevel)
            return 100; // Max level reached

        return PlantGrowthCalculator.GetReadingDaysPercentage(
            Plant.CurrentLevel,
            Plant.ReadingDaysCount,
            Plant.Species.GrowthRate,
            Plant.Species.MaxLevel,
            _growthMultiplier
        );
    }

    private int GetDaysToNextLevel()
    {
        if (Plant.Species == null) return 0;
        return PlantGrowthCalculator.GetReadingDaysToNextLevel(
            Plant.CurrentLevel,
            Plant.ReadingDaysCount,
            Plant.Species.GrowthRate,
            Plant.Species.MaxLevel,
            _growthMultiplier
        );
    }

    private string GetDaysUntilWater()
    {
        if (Plant.Species == null) return "?";
        var daysUntil = PlantGrowthCalculator.GetDaysUntilWaterNeeded(
            Plant.LastWatered,
            Plant.Species.WaterIntervalDays,
            _growthMultiplier
        );

        return $"{daysUntil:F1}";
    }
}

