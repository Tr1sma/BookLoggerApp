@using BookLoggerApp.Core.Models
@using BookLoggerApp.Core.Resources
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<AppResources> L

@if (IsVisible && Book != null)
{
    <div class="celebration-overlay" @onclick="HandleClose">
        <div class="celebration-card" @onclick:stopPropagation="true">
            <!-- Confetti particles -->
            @for (int i = 0; i < 12; i++)
            {
                <div class="confetti"></div>
            }

            <!-- Header -->
            <div class="book-complete-header">
                <h1>📚 @L["BookCompletion_Header"]</h1>
            </div>

            <!-- Book Info -->
            <div class="completed-book-info">
                <h2>@Book.Title</h2>
                <p class="book-author">@L["Dashboard_By"] @Book.Author</p>
            </div>

            <!-- XP Reward -->
            <div class="xp-reward">
                <span class="xp-reward-label">@L["BookCompletion_YouEarned"]</span>
                <span class="xp-reward-value">✨ @TotalXpEarned XP</span>
            </div>

            <!-- Continue Button -->
            <button class="celebration-button" @onclick="HandleClose">
                @L["BookCompletion_Awesome"]
            </button>

            @if (ShowShareButton)
            {
                <button class="celebration-button celebration-share-button"
                        @onclick="OnShareBook"
                        disabled="@IsGeneratingCard">
                    @if (IsGeneratingCard)
                    {
                        <span>@L["Stats_Generating"]</span>
                    }
                    else
                    {
                        <span>📤 @L["BookDetail_ShareAsRecommendation"]</span>
                    }
                </button>
            }
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public Book? Book { get; set; }
    [Parameter] public int TotalXpEarned { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public bool ShowShareButton { get; set; }
    [Parameter] public bool IsGeneratingCard { get; set; }
    [Parameter] public EventCallback OnShareBook { get; set; }

    private async Task HandleClose()
    {
        await OnClose.InvokeAsync();
    }
}
