@using BookLoggerApp.Core.Models
@using BookLoggerApp.Core.Resources
@using BookLoggerApp.Core.Services.Abstractions
@using BookLoggerApp.Core.ViewModels
@using Microsoft.Extensions.Localization
@implements IDisposable
@inject AppStartupViewModel ViewModel
@inject ITimerStateService TimerStateService
@inject IBackButtonService BackButtonService
@inject NavigationManager NavigationManager
@inject IStringLocalizer<AppResources> L

@if (ViewModel.HasVisibleOverlay)
{
    <div class="startup-overlay">
        @if (ViewModel.IsOnboardingVisible)
        {
            <div class="startup-modal" role="dialog" aria-modal="true" aria-labelledby="startupOnboardingTitle">
                <OnboardingTutorial
                    CurrentStep="@ViewModel.OnboardingCurrentStep"
                    TotalSteps="@ViewModel.OnboardingStepCount"
                    ShowSkipConfirmation="@ViewModel.IsOnboardingSkipConfirmationVisible"
                    OnSkipRequested="HandleRequestSkipOnboardingAsync"
                    OnSkipConfirmed="HandleSkipOnboardingAsync"
                    OnSkipCancelled="HandleCancelSkipOnboardingAsync"
                    OnBack="HandleOnboardingBackAsync"
                    OnNext="HandleOnboardingNextAsync"
                    OnComplete="HandleCompleteOnboardingAsync"
                    OnAddFirstBook="HandleAddFirstBookAsync" />
            </div>
        }

        @if (ViewModel.IsChangelogVisible)
        {
            <div class="startup-modal" role="dialog" aria-modal="true" aria-labelledby="startupChangelogTitle">
                <div class="startup-modal-header">
                    <div>
                        <h2 id="startupChangelogTitle">@L["Startup_WhatsNew"]</h2>
                        @if (ViewModel.CurrentRelease != null)
                        {
                            <p class="startup-subtitle">
                                @L["Settings_Version"] @ViewModel.CurrentRelease.DisplayVersion
                                @if (!string.IsNullOrWhiteSpace(ViewModel.CurrentRelease.ReleaseDate))
                                {
                                    <span>- @ViewModel.CurrentRelease.ReleaseDate</span>
                                }
                            </p>
                        }
                    </div>
                    @if (ViewModel.ReleaseHistory.Count > 1)
                    {
                        <button type="button" class="history-toggle" @onclick="ViewModel.ToggleHistoryAsync">
                            <span aria-hidden="true">@(ViewModel.ShowFullHistory ? "▲" : "▼")</span>
                            <span>@(ViewModel.ShowFullHistory ? L["Startup_HideHistory"].Value : L["Startup_ShowHistory"].Value)</span>
                        </button>
                    }
                </div>

                <div class="startup-modal-body">
                    @foreach (var release in GetVisibleReleases())
                    {
                        <section class="release-card">
                            <div class="release-card-header">
                                <h3>@L["Settings_Version"] @release.DisplayVersion</h3>
                                @if (!string.IsNullOrWhiteSpace(release.ReleaseDate))
                                {
                                    <span>@release.ReleaseDate</span>
                                }
                            </div>

                            @foreach (var releaseSection in release.Sections)
                            {
                                <div class="release-section">
                                    <h4>@releaseSection.Title</h4>
                                    <ul>
                                        @foreach (var entry in releaseSection.Entries)
                                        {
                                            <li>@entry</li>
                                        }
                                    </ul>
                                </div>
                            }
                        </section>
                    }
                </div>

                <div class="startup-modal-actions">
                    <button type="button" class="btn btn-primary" @onclick="ViewModel.CloseChangelogAsync">
                        @L["Session_Continue"]
                    </button>
                </div>
            </div>
        }

        @if (ViewModel.IsUpdateAvailableVisible)
        {
            <div class="startup-modal startup-modal-compact" role="dialog" aria-modal="true" aria-labelledby="startupUpdateTitle">
                <div class="startup-modal-header">
                    <div>
                        <h2 id="startupUpdateTitle">@L["Startup_UpdateAvailable_Title"]</h2>
                        <p class="startup-subtitle">@L["Startup_UpdateAvailable_Subtitle"]</p>
                    </div>
                </div>

                <div class="startup-modal-body">
                    <p>
                        @L["Startup_UpdateAvailable_Body"]
                    </p>
                </div>

                <div class="startup-modal-actions">
                    <button type="button" class="btn btn-secondary" @onclick="ViewModel.DismissUpdateAvailableAsync" disabled="@ViewModel.IsStartingUpdate">
                        @L["Startup_Later"]
                    </button>
                    <button type="button" class="btn btn-primary" @onclick="async () => await ViewModel.StartFlexibleUpdateAsync()" disabled="@ViewModel.IsStartingUpdate">
                        @(ViewModel.IsStartingUpdate ? L["Startup_Starting"].Value : L["Startup_UpdateNow"].Value)
                    </button>
                </div>
            </div>
        }

        @if (ViewModel.IsUpdateReadyVisible)
        {
            <div class="startup-modal startup-modal-compact" role="dialog" aria-modal="true" aria-labelledby="startupInstallTitle">
                <div class="startup-modal-header">
                    <div>
                        <h2 id="startupInstallTitle">@L["Startup_UpdateReady_Title"]</h2>
                        <p class="startup-subtitle">@L["Startup_UpdateReady_Subtitle"]</p>
                    </div>
                </div>

                <div class="startup-modal-body">
                    <p>
                        @L["Startup_UpdateReady_Body"]
                    </p>
                </div>

                <div class="startup-modal-actions">
                    <button type="button" class="btn btn-secondary" @onclick="ViewModel.DismissUpdateReadyAsync">
                        @L["Startup_Later"]
                    </button>
                    <button type="button" class="btn btn-primary" @onclick="async () => await ViewModel.CompleteUpdateAsync()">
                        @L["Startup_InstallNow"]
                    </button>
                </div>
            </div>
        }
    </div>
}

@code {
    private Func<Task<bool>>? _backHandler;

    protected override void OnInitialized()
    {
        ViewModel.PropertyChanged += HandleViewModelPropertyChanged;
        TimerStateService.AppResumed += HandleAppResumed;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await ViewModel.InitializeAsync();
        SyncBackHandler();
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        ViewModel.PropertyChanged -= HandleViewModelPropertyChanged;
        TimerStateService.AppResumed -= HandleAppResumed;

        if (_backHandler != null)
        {
            BackButtonService.Unregister(_backHandler);
            _backHandler = null;
        }
    }

    private IReadOnlyList<ChangelogRelease> GetVisibleReleases()
    {
        if (ViewModel.ShowFullHistory)
        {
            return ViewModel.ReleaseHistory;
        }

        return ViewModel.CurrentRelease != null
            ? new[] { ViewModel.CurrentRelease }
            : Array.Empty<ChangelogRelease>();
    }

    private void HandleAppResumed()
    {
        _ = InvokeAsync(async () =>
        {
            await ViewModel.HandleAppResumedAsync();
            SyncBackHandler();
            StateHasChanged();
        });
    }

    private void HandleViewModelPropertyChanged(object? sender, System.ComponentModel.PropertyChangedEventArgs e)
    {
        _ = InvokeAsync(() =>
        {
            SyncBackHandler();
            StateHasChanged();
        });
    }

    private void SyncBackHandler()
    {
        if (ViewModel.HasVisibleOverlay && _backHandler == null)
        {
            _backHandler = async () => await ViewModel.HandleBackAsync();
            BackButtonService.Register(_backHandler);
            return;
        }

        if (!ViewModel.HasVisibleOverlay && _backHandler != null)
        {
            BackButtonService.Unregister(_backHandler);
            _backHandler = null;
        }
    }

    private async Task HandleSkipOnboardingAsync()
    {
        try
        {
            await ViewModel.SkipOnboardingAsync();
        }
        catch
        {
            ViewModel.DismissOnboarding();
        }
        NavigationManager.NavigateTo("/getting-started");
    }

    private async Task HandleCompleteOnboardingAsync()
    {
        try
        {
            await ViewModel.CompleteOnboardingAsync();
        }
        catch
        {
            ViewModel.DismissOnboarding();
        }
        NavigationManager.NavigateTo("/getting-started");
    }

    private async Task HandleAddFirstBookAsync()
    {
        try
        {
            await ViewModel.CompleteOnboardingAsync();
        }
        catch
        {
            ViewModel.DismissOnboarding();
        }
        NavigationManager.NavigateTo("/books/new");
    }

    private async Task HandleOnboardingNextAsync()
    {
        await ViewModel.AdvanceOnboardingAsync();
    }

    private async Task HandleOnboardingBackAsync()
    {
        if (ViewModel.OnboardingCurrentStep > 0)
        {
            await ViewModel.RetreatOnboardingAsync();
            return;
        }

        await ViewModel.RequestSkipOnboardingAsync();
    }

    private async Task HandleRequestSkipOnboardingAsync()
    {
        await ViewModel.RequestSkipOnboardingAsync();
    }

    private async Task HandleCancelSkipOnboardingAsync()
    {
        await ViewModel.CancelSkipOnboardingAsync();
    }
}
