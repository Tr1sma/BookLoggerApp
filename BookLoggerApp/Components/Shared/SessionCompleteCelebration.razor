@using BookLoggerApp.Core.Models
@using BookLoggerApp.Core.Resources
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<AppResources> L

@if (Result != null)
{
    <div class="celebration-overlay" @onclick="HandleClose">
        <div class="celebration-card" @onclick:stopPropagation="true">
            <!-- Confetti particles -->
            @for (int i = 0; i < 9; i++)
            {
                <div class="confetti"></div>
            }

            <!-- Header -->
            <div class="session-complete-header">
                <h1>🎉 @L["Session_Header"]</h1>
            </div>

            @if (StreakRescuedByGuardian)
            {
                <div class="ability-callout">
                    ✨ <strong>@L["Session_StreakGuardianSaved"]</strong>
                </div>
            }

            @if (StoryHeartCoinBonus > 0 || StoryHeartFirstOfDayBonusXp > 0)
            {
                <div class="ability-callout">
                    💖 <strong>@L["Session_StoryHeart_Title"]:</strong>
                    @if (StoryHeartCoinBonus > 0)
                    {
                        <span>@L["Session_StoryHeart_Coins", StoryHeartCoinBonus]</span>
                    }
                    @if (StoryHeartCoinBonus > 0 && StoryHeartFirstOfDayBonusXp > 0)
                    {
                        <span>, </span>
                    }
                    @if (StoryHeartFirstOfDayBonusXp > 0)
                    {
                        <span>@L["Session_StoryHeart_FirstOfDayXp", StoryHeartFirstOfDayBonusXp]</span>
                    }
                </div>
            }

            <!-- XP Breakdown -->
            <div class="xp-breakdown">

                @if (Result.PagesXp > 0)
                {
                    <div class="xp-row">
                        <span class="xp-label">@L["Session_Row_Pages"]</span>
                        <span class="xp-value">+@Result.PagesXp XP</span>
                    </div>
                }

                @if (Result.MinutesXp > 0)
                {
                    <div class="xp-row">
                        <span class="xp-label">@L["Session_Row_Time"]</span>
                        <span class="xp-value">+@Result.MinutesXp XP</span>
                    </div>
                }

                @if (Result.LongSessionBonusXp > 0)
                {
                    <div class="xp-row">
                        <span class="xp-label">@L["Session_Row_LongBonus"]</span>
                        <span class="xp-value">+@Result.LongSessionBonusXp XP</span>
                    </div>
                }

                @if (Result.BookCompletionXp > 0)
                {
                    <div class="xp-row">
                        <span class="xp-label">@L["Session_Row_BookCompleted"]</span>
                        <span class="xp-value">+@Result.BookCompletionXp XP</span>
                    </div>
                }

                @if (Result.StreakBonusXp > 0)
                {
                    <div class="xp-row">
                        <span class="xp-label">@L["Session_Row_StreakBonus"]</span>
                        <span class="xp-value">+@Result.StreakBonusXp XP</span>
                    </div>
                }

                <div class="xp-divider"></div>

                <div class="xp-row subtotal">
                    <span class="xp-label">@L["Session_Row_Subtotal"]</span>
                    <span class="xp-value">@Result.BaseXp XP</span>
                </div>

                @if (Result.PlantBoostPercentage > 0)
                {
                    <div class="xp-row">
                        <span class="xp-label">🌱 @L["Session_Row_PlantBoost", Math.Round(Result.PlantBoostPercentage * 100)]</span>
                        <span class="xp-value">+@Result.BoostedXp XP</span>
                    </div>
                }

                <div class="xp-divider"></div>

                <div class="xp-row total-row">
                    <span class="xp-label">@L["Session_Row_Total"]</span>
                    <span class="xp-value total">@Result.XpEarned XP</span>
                </div>
            </div>

            <!-- Progress bar (optional) -->


            <!-- Continue Button -->
            <button class="celebration-button" @onclick="HandleClose">
                @L["Session_Continue"]
            </button>
        </div>
    </div>
}

@code {
    [Parameter] public ProgressionResult? Result { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public bool ShowProgressBar { get; set; } = true;
    [Parameter] public decimal ProgressPercentage { get; set; } = 0;
    [Parameter] public bool StreakRescuedByGuardian { get; set; }
    [Parameter] public int StoryHeartCoinBonus { get; set; }
    [Parameter] public int StoryHeartFirstOfDayBonusXp { get; set; }

    private async Task HandleClose()
    {
        await OnClose.InvokeAsync();
    }
}
