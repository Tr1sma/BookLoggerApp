@using BookLoggerApp.Core.Resources
@using Microsoft.Extensions.Localization
@inject NavigationManager Navigation
@inject IStringLocalizer<AppResources> L

<nav class="bottom-nav">
    <NavLink class="nav-item" href="/" Match="NavLinkMatch.All">
        <span class="nav-icon">📚</span>
        <span class="nav-label">@L["Nav_Bookshelf"]</span>
    </NavLink>

    <NavLink class="nav-item" href="/dashboard">
        <span class="nav-icon">🏠</span>
        <span class="nav-label">@L["Nav_Dashboard"]</span>
    </NavLink>

    <NavLink class="nav-item" href="/stats">
        <span class="nav-icon">📊</span>
        <span class="nav-label">@L["Nav_Stats"]</span>
    </NavLink>

    <NavLink class="nav-item" href="/goals">
        <span class="nav-icon">🎯</span>
        <span class="nav-label">@L["Nav_Goals"]</span>
    </NavLink>

    <NavLink class="nav-item" href="/shop">
        <span class="nav-icon">🌱</span>
        <span class="nav-label">@L["Nav_Shop"]</span>
    </NavLink>

    <NavLink class="nav-item" href="/settings">
        <span class="nav-icon">⚙️</span>
        <span class="nav-label">@L["Nav_Settings"]</span>
    </NavLink>
</nav>

@code {
    // Bottom navigation component for mobile-first design
    // Uses NavLink for automatic active state handling
}
